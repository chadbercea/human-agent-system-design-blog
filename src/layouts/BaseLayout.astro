---
import '../styles/fonts.css';
import '../styles/homepage.css';

interface Props {
  title: string;
  activeNav?: 'articles' | 'about' | 'contact';
}

const { title, activeNav = 'articles' } = Astro.props;
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
</head>
<body>
  <div class="shell">
    <header class="header">
      <a href="/" class="brand">
        <span class="brand-full">Human Agent System Design</span>
        <span class="brand-short">HAS Design</span>
      </a>
      <nav class="nav">
        <a href="/" class={activeNav === 'articles' ? 'on' : undefined}>Articles</a>
        <a href="/about" class={activeNav === 'about' ? 'on' : undefined}>About</a>
        <a href="/contact" class={activeNav === 'contact' ? 'on' : undefined}>Contact</a>
      </nav>
    </header>

    <slot />

    <footer class="footer">
      <span>HAS Design</span>
      <span>MMXXVI</span>
    </footer>
  </div>

  <slot name="after-shell" />
</body>
</html>
