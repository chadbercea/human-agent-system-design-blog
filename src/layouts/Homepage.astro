---
import '../styles/homepage.css';
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>HAS Design</title>
</head>
<body>
  <div class="shell">
    <header class="header">
      <a href="/" class="brand">
        <span class="brand-full">Human Agent System Design</span>
        <span class="brand-short">HAS Design</span>
      </a>
      <nav class="nav">
        <a href="/" class="on">Articles</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
      </nav>
    </header>

    <div class="stage" id="stage">
      <div class="col col-hero">
        <div class="hero-inner">
          <div class="eyebrow">Human · Agent · System Design</div>
          <h1 class="h1">A new<br>discipline<br>for agentic<br>systems.</h1>
          <p class="desc">HAS Design is the practice of designing multi-actor orchestrations where humans, agents, and software coordinate autonomously to produce outcomes none could achieve alone.</p>
        </div>
        <button class="back-btn" id="back-btn" aria-label="Back to articles">
          <span class="back-content">
            <span class="back-arrow">←</span>
            <span>Back</span>
          </span>
        </button>
      </div>
      <div class="col col-list"></div>
      <div class="col col-article"></div>
    </div>

    <footer class="footer">
      <span>HAS Design</span>
      <span>MMXXVI</span>
    </footer>
  </div>
</body>
</html>
