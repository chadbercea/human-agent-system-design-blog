---
import { ClientRouter } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';
import '../styles/tokens.css';
import '../styles/chrome.css';
import '../styles/motion.css';
import '../styles/entry.css';
import '../styles/transitions.css';
import '../styles/homepage.css';
import '../styles/framework-locator.css';
import '../styles/concept-link.css';
import '../styles/hover.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteRails from '../components/SiteRails.astro';
import { getChannelForPath } from '../lib/channels';

interface Props {
  title: string;
  description?: string;
  activeNav?: 'articles' | 'glossary' | 'design-system' | 'diagnostic' | 'reading-list' | 'system-recipes' | 'about' | 'contact';
  railTag?: string;
  chrome?: 'full' | 'minimal' | 'none';
  noindex?: boolean;
  ogTitle?: string;
  ogDescription?: string;
}

const {
  title,
  description = 'A blog about Human-Agent-System Design. Humans, agents, and systems shipping products together.',
  activeNav = 'articles',
  railTag,
  chrome = 'full',
  noindex = false,
  ogTitle,
  ogDescription,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const channel = getChannelForPath(Astro.url.pathname);
const railTagText = railTag ?? channel.tag;
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex" />}
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&family=Lato:wght@100;300;400;700;900&display=swap" rel="stylesheet" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="HAS Design" />
  <meta property="og:title" content={ogTitle ?? title} />
  <meta property="og:description" content={ogDescription ?? description} />
  <meta property="og:url" content={canonical} />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={ogTitle ?? title} />
  <meta name="twitter:description" content={ogDescription ?? description} />
  <ClientRouter />
</head>
<body data-chrome={chrome} data-channel-id={channel.id} data-channel-label={channel.label} data-flourish={channel.flourish ?? 'none'}>
  <SiteRails tag={railTagText} />
  <div class="shell">
    <SiteHeader activeNav={activeNav} />

    <slot />

    <SiteFooter />
  </div>

  <slot name="after-shell" />

  <Analytics />

  <script>
    import { mountReveals } from '../lib/reveals';
    import { mountChannelTransitions } from '../lib/channelTransition';
    mountReveals();
    mountChannelTransitions();
    document.addEventListener('astro:page-load', () => mountReveals());

    // ILI-789 — flag any in-app navigation (logo click, link, or
    // popstate via ClientRouter) so a subsequent landing on `/`
    // skips the cold-load boot sequence. Cleared only on tab
    // close (sessionStorage scope).
    document.addEventListener('astro:before-preparation', () => {
      try { sessionStorage.setItem('has_navigated_in_session', '1'); } catch (e) {}
    });
  </script>
</body>
</html>
