---
import '../styles/global.css';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '' } = Astro.props;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : null;
const pathname = Astro.url.pathname;
const currentSlug = pathname === '/' || pathname.startsWith('/tags') || pathname.startsWith('/series') || pathname.startsWith('/reading') || pathname.startsWith('/page')
  ? null
  : pathname.replace(/^\//, '').split('/')[0] ?? null;

const allPosts = (await getCollection('blog')).filter((p) => !p.data.draft);
const foundations = [...allPosts]
  .filter((p) => p.data.series === 'foundations')
  .sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0));
const foundationsSlugs = new Set(foundations.map((p) => p.slug));
const allOtherArticles = [...allPosts]
  .filter((p) => !foundationsSlugs.has(p.slug))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

function excerpt(text: string, maxLen = 80) {
  if (text.length <= maxLen) return text;
  return text.slice(0, maxLen).trim() + (text.length > maxLen ? '…' : '');
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,100..900;1,9..144,100..900&family=IBM+Plex+Mono:wght@400;500;700&family=Poppins:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
  </head>
  <body class="blog-layout">
    <div class="blog-shell">
      <aside class="sidebar" aria-label="Blog navigation">
        <div class="sidebar-branding">
          <h1 class="sidebar-branding__title">HAS DESIGN</h1>
          <p class="sidebar-branding__tagline">HUMAN-AGENT-SYSTEM DESIGN</p>
          <hr class="rule" />
        </div>
        <div class="sidebar-foundations">
          <p class="sidebar-section-label sidebar-section-label--vector">FOUNDATIONS</p>
          {foundations.map((post) => (
            <a
              href={`/${post.slug}`}
              class:list={['sidebar-article', currentSlug === post.slug && 'active']}
              data-slug={post.slug}
            >
              <span class="article-title">{post.data.title}</span>
              <span class="article-excerpt">{excerpt(post.data.description)}</span>
              <span class="article-meta">
                {post.data.readingTime} MIN · PART {post.data.seriesPart} OF {post.data.seriesTotal ?? foundations.length}
              </span>
            </a>
          ))}
          <hr class="rule" />
        </div>
        <div class="sidebar-all-articles">
          <p class="sidebar-section-label">ALL ARTICLES</p>
          {allOtherArticles.map((post) => (
            <a
              href={`/${post.slug}`}
              class:list={['sidebar-article', currentSlug === post.slug && 'active']}
              data-slug={post.slug}
            >
              <span class="article-title">{post.data.title}</span>
              <span class="article-excerpt">{excerpt(post.data.description)}</span>
              <span class="article-meta">
                {post.data.readingTime} MIN
                {post.data.series != null && post.data.seriesPart != null && post.data.seriesTotal != null && (
                  <> · PART {post.data.seriesPart} OF {post.data.seriesTotal}</>
                )}
              </span>
            </a>
          ))}
        </div>
      </aside>
      <main class="content-panel" id="content-panel">
        <slot />
        <footer class="blog-footer">
          <p>
            Human–agent system design
            · <a href="/demo" class="vector">Design demo</a>
          </p>
        </footer>
      </main>
    </div>
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const rules = document.querySelectorAll('hr.rule');
        const ruleObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                ruleObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, root: document.getElementById('content-panel') }
        );
        rules.forEach((rule) => ruleObserver.observe(rule));

        const animateEls = document.querySelectorAll('.animate-in');
        const animateObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('visible');
                animateObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.1, root: document.getElementById('content-panel') }
        );
        animateEls.forEach((el) => animateObserver.observe(el));

        document.querySelectorAll('.altitude-band, .sector-list').forEach((container) => {
          container.querySelectorAll('.animate-in').forEach((el, i) => {
            (el as HTMLElement).style.transitionDelay = `${i * 100}ms`;
          });
        });
      });
    </script>
  </body>
</html>

<style>
  .blog-shell {
    display: flex;
    height: 100vh;
    overflow: hidden;
  }

  .sidebar {
    width: 20%;
    min-width: 260px;
    max-width: 320px;
    height: 100vh;
    flex-shrink: 0;
    background-color: var(--color-bg);
    border-right: 1px solid var(--color-rule);
    padding: var(--space-lg) var(--space-md);
    display: flex;
    flex-direction: column;
  }

  .sidebar-branding {
    flex-shrink: 0;
  }

  .sidebar-branding__title {
    font-family: var(--font-editorial);
    font-weight: 900;
    font-size: 1.5rem;
    color: var(--color-text);
    line-height: 1.1;
    margin: 0 0 4px;
  }

  .sidebar-branding__tagline {
    font-family: var(--font-system);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    color: var(--color-text-dim);
    margin: 0 0 var(--space-md);
  }

  .sidebar .rule {
    transform: scaleX(1); /* always visible in sidebar */
  }

  .sidebar-branding .rule {
    margin: 0 0 var(--space-md);
  }

  .sidebar-foundations {
    flex-shrink: 0;
  }

  .sidebar-foundations .rule {
    margin: 0 0 var(--space-md);
  }

  .sidebar-section-label {
    font-family: var(--font-system);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 var(--space-xs);
  }

  .sidebar-section-label--vector {
    color: var(--color-vector);
  }

  .sidebar-all-articles {
    flex: 1;
    overflow-y: auto;
    min-height: 0;
  }

  .sidebar-article {
    display: block;
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--color-rule);
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: background-color 200ms ease-out;
  }

  .sidebar-article:hover {
    background-color: rgba(255, 255, 255, 0.03);
  }

  .sidebar-article .article-title {
    display: block;
    font-family: var(--font-human);
    font-weight: 600;
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: 1.3;
    margin-bottom: 4px;
  }

  .sidebar-article .article-excerpt {
    display: block;
    font-family: var(--font-human);
    font-weight: 400;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 4px;
  }

  .sidebar-article .article-meta {
    display: block;
    font-family: var(--font-system);
    font-size: var(--text-xs);
    color: var(--color-text-dim);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .sidebar-article.active {
    border-left: 2px solid var(--color-vector);
    padding-left: var(--space-sm);
  }

  .content-panel {
    flex: 1;
    min-width: 0;
    height: 100vh;
    overflow-y: auto;
    background-color: var(--color-bg);
    padding: var(--space-xl) var(--space-xl);
  }

  .blog-footer {
    margin-top: var(--space-xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-rule);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .blog-footer p {
    margin: 0;
  }

  @media (max-width: 900px) {
    .blog-shell {
      flex-direction: column;
    }
    .sidebar {
      width: 100%;
      max-width: none;
      height: auto;
      min-height: auto;
      flex-shrink: 0;
      border-right: none;
      border-bottom: 1px solid var(--color-rule);
    }
    .content-panel {
      width: 100%;
      height: auto;
      flex: 1;
      min-height: 0;
    }
  }
</style>
