---
import SiteLayout from './SiteLayout.astro';

interface Props {
  title: string;
  date: Date;
  description?: string;
}

const { title, date, description } = Astro.props;

const year = date.getFullYear();
const month = String(date.getMonth() + 1).padStart(2, '0');
const day = String(date.getDate()).padStart(2, '0');
const formattedDate = `${year}.${month}.${day}`;
---

<SiteLayout title={title} description={description}>
  <div class="page-scroll">
    <header class="article-header">
      <h1 class="article-header__title">{title}</h1>
      <div class="article-header__date">{formattedDate}</div>
      {description && (
        <p class="article-header__lede">{description}</p>
      )}
    </header>
    <article class="prose">
      <slot />
    </article>
    <footer class="article-footer">
      <a href="/">&larr; Back</a>
    </footer>
  </div>
</SiteLayout>

<style>
  .page-scroll {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    overflow-y: auto;
    overflow-x: hidden;
    padding: clamp(2rem, 4vh, 4rem) clamp(1.5rem, 3vw, 3rem);
  }

  .article-header {
    margin-bottom: clamp(2rem, 4vw, 4rem);
  }

  .article-header__title {
    margin: 0;
    font-family: var(--font-prose);
    font-size: var(--text-title);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
  }

  .article-header__date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-3);
  }

  .article-header__lede {
    max-width: clamp(45ch, 60vw, 75ch);
    margin: var(--space-4) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
  }

  .prose {
    max-width: clamp(45ch, 60vw, 75ch);
  }

  .article-footer {
    margin-top: clamp(3rem, 6vw, 6rem);
  }

  .article-footer a {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .article-footer a:hover {
    color: var(--color-accent);
  }
</style>
