---
import SiteLayout from './SiteLayout.astro';
import { type ArticleEntry } from '../lib/articles.ts';

interface Props {
  title: string;
  date: Date;
  description?: string;
  readingTime: number;
  articles: ArticleEntry[];
}

const { title, date, description, readingTime, articles } = Astro.props;

const dateLabel = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
});
---

<SiteLayout title={title} description={description} articles={articles}>
  <header class="article-header">
    <h1>{title}</h1>
    <hr class="article-header__rule" />
    <p class="article-header__meta">
      {dateLabel}
      <span aria-hidden="true"> &middot; </span>
      {readingTime} min read
    </p>
  </header>
  {description && <p class="article-lede">{description}</p>}
  <div class="article__body">
    <slot />
  </div>
  <footer class="article-footer">
    <a href="/">&larr; All articles</a>
  </footer>
</SiteLayout>

<style>
  .article-header {
    max-width: var(--measure-prose);
    margin-bottom: var(--space-8);
  }

  .article-header h1 {
    margin: 0 0 var(--space-4);
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 900;
    line-height: var(--leading-tight);
    letter-spacing: -0.03em;
  }

  .article-header__rule {
    height: 0;
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 0 0 var(--space-3);
  }

  .article-header__meta {
    margin: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-variant-numeric: tabular-nums;
    color: var(--color-text-muted);
  }

  .article-lede {
    max-width: var(--measure-prose);
    margin: 0 0 var(--space-8);
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    line-height: var(--leading-loose);
  }

  .article__body {
    max-width: var(--measure-prose);
  }

  .article-footer {
    max-width: var(--measure-prose);
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border);
  }

  .article-footer a {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }
</style>
