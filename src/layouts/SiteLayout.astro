---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import { type ArticleEntry } from '../lib/articles.ts';

interface Props {
  title: string;
  description?: string;
  articles: ArticleEntry[];
}

const { title, description = '', articles } = Astro.props;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
  </head>
  <body>
    <div class="layout">
      <aside class="layout__sidebar">
        <Sidebar articles={articles} currentPath={Astro.url.pathname} />
      </aside>
      <div class="layout__content">
        <slot />
      </div>
    </div>
  </body>
</html>
