---
import CategoryGlyph from './CategoryGlyph.astro';
import {
  categoryHref,
  getAllCategoriesWithMembers,
  getFramework,
  type CategorySlug,
} from '../lib/has-framework';

interface Props {
  currentCategory?: CategorySlug;
  class?: string;
}

const { currentCategory, class: className } = Astro.props;

const [framework, categories] = await Promise.all([
  getFramework(),
  getAllCategoriesWithMembers(),
]);
---

<nav
  class:list={['framework-locator', className]}
  aria-label="HAS-D framework navigation"
>
  <span class="framework-locator-eyebrow">// {framework?.data.title ?? 'HAS-D FRAMEWORK'}</span>
  <ul class="framework-locator-cells">
    {categories.map((c) => {
      const isCurrent = c.data.slug === currentCategory;
      return (
        <li class:list={['framework-locator-cell', `framework-locator-cell--${c.data.slug}`, isCurrent && 'is-current']}>
          <a
            href={categoryHref(c.data.slug)}
            aria-current={isCurrent ? 'page' : undefined}
          >
            <span class="framework-locator-glyph">
              <CategoryGlyph category={c.data.slug} size={16} />
            </span>
            <span class="framework-locator-name">{c.data.plural}</span>
            <span class="framework-locator-count">{c.member_count}</span>
          </a>
        </li>
      );
    })}
  </ul>
</nav>

<style>
  .framework-locator {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .framework-locator-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--dim);
  }
  .framework-locator-cells {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--rule-strong);
    border: 1px solid var(--rule-strong);
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .framework-locator-cell { background: var(--bg-canvas); }
  .framework-locator-cell a {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    text-decoration: none;
    color: var(--mid);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    transition:
      color var(--dur-fast) var(--ease-out),
      background-color var(--dur-fast) var(--ease-out);
  }
  .framework-locator-glyph {
    display: inline-flex;
    color: var(--dim);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .framework-locator-name {
    color: inherit;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .framework-locator-count {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--dim);
  }

  /* Hover (any cell) — lift to light, glyph picks up category color */
  .framework-locator-cell a:hover { color: var(--light); background: rgba(255, 255, 255, 0.02); }
  .framework-locator-cell--axioms a:hover .framework-locator-glyph,
  .framework-locator-cell--axioms.is-current .framework-locator-glyph { color: var(--cat-axioms); }
  .framework-locator-cell--constraints a:hover .framework-locator-glyph,
  .framework-locator-cell--constraints.is-current .framework-locator-glyph { color: var(--cat-constraints); }
  .framework-locator-cell--design-requirements a:hover .framework-locator-glyph,
  .framework-locator-cell--design-requirements.is-current .framework-locator-glyph { color: var(--cat-design-requirements); }

  /* Current — full color label, lighter count, subtle category-tinted top rule */
  .framework-locator-cell.is-current a { color: var(--white); }
  .framework-locator-cell.is-current .framework-locator-count { color: var(--light); }
  .framework-locator-cell--axioms.is-current a { box-shadow: inset 0 1px 0 var(--cat-axioms); }
  .framework-locator-cell--constraints.is-current a { box-shadow: inset 0 1px 0 var(--cat-constraints); }
  .framework-locator-cell--design-requirements.is-current a { box-shadow: inset 0 1px 0 var(--cat-design-requirements); }
  .framework-locator-cell--axioms.is-current a:hover,
  .framework-locator-cell--constraints.is-current a:hover,
  .framework-locator-cell--design-requirements.is-current a:hover {
    background: rgba(255, 255, 255, 0.02);
  }

  .framework-locator-cell a:focus-visible {
    outline: 1px solid var(--white);
    outline-offset: -2px;
  }

  @media (max-width: 720px) {
    .framework-locator-cells { grid-template-columns: 1fr; }
    .framework-locator-cell a { padding: 12px 16px; }
    /* On stacked layout, the glyph carries category, the count moves to its own row */
    .framework-locator-cell--axioms.is-current a { box-shadow: inset 2px 0 0 var(--cat-axioms); }
    .framework-locator-cell--constraints.is-current a { box-shadow: inset 2px 0 0 var(--cat-constraints); }
    .framework-locator-cell--design-requirements.is-current a { box-shadow: inset 2px 0 0 var(--cat-design-requirements); }
  }
</style>
