---
interface Props {
  tag?: string;
}

const {
  tag = 'HUMAN · AGENT · SYSTEM',
} = Astro.props;
---
<div class="rail rail--left" aria-hidden="true">
  <span>
    <em data-rail-tag data-channel-tag data-rail-tag-default={tag}>{tag}</em>&nbsp;&nbsp;/&nbsp;&nbsp;PROTOCOL 001&nbsp;&nbsp;/&nbsp;&nbsp;PHASE ALPHA
  </span>
</div>

<script is:inline>
  (function () {
    if (window.__hasRailsInit) return;
    window.__hasRailsInit = true;
    window.HASRails = {
      set: function (opts) {
        opts = opts || {};
        var tag = document.querySelector('[data-rail-tag]');
        if (tag && typeof opts.tag === 'string') tag.textContent = opts.tag;
      },
      reset: function () {
        var tag = document.querySelector('[data-rail-tag]');
        if (tag) tag.textContent = tag.getAttribute('data-rail-tag-default') || '';
      },
    };
  })();
</script>

<style is:global>
  .rail {
    position: fixed;
    top: 0; bottom: 0;
    width: 32px;
    z-index: 2;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--white);
    background: var(--black);
  }
  .rail--left {
    left: 0;
    border-right: 1px solid var(--rule);
    transition: transform var(--dur-base) var(--ease-inout);
    will-change: transform;
  }
  body.article-open .rail--left {
    transform: translateX(-100%);
  }

  /* ILI-781 — left rail cascade. During the hero sequence the
     rail is revealed top-to-bottom via clip-path inset; visually
     reads as the vertical text writing in. The bg stays full-rail
     so the reveal only affects the text glyphs, not the rail
     itself. Stage 5 = 1400ms start, 400ms duration. */
  body.hero-sequence-play .rail--left span {
    clip-path: inset(0 0 100% 0);
    animation: hero-seq-rail 400ms var(--ease-out) 1400ms forwards;
    will-change: clip-path;
  }
  @media (prefers-reduced-motion: reduce) {
    body.hero-sequence-play .rail--left span {
      animation: none;
      clip-path: none;
    }
  }
  .rail span { writing-mode: vertical-rl; text-orientation: mixed; white-space: nowrap; }
  .rail em { color: var(--white); font-style: normal; font-weight: 600; }

  @media (max-width: 900px) {
    .rail { display: none; }
  }
</style>
