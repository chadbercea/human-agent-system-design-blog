---
interface Props {
  left?: string;
  channel?: string;
}

const {
  left = 'HUMAN · AGENT · SYSTEM',
  channel = 'CH 01 · SIGNAL STRONG',
} = Astro.props;
---
<div class="rail rail--left" aria-hidden="true">
  <span><em>{left}</em>&nbsp;&nbsp;/&nbsp;&nbsp;PROTOCOL 001&nbsp;&nbsp;/&nbsp;&nbsp;PHASE ALPHA</span>
</div>
<div class="rail rail--right" aria-hidden="true">
  <span>{channel}&nbsp;&nbsp;/&nbsp;&nbsp;<em>LIVE TRANSMISSION</em>&nbsp;&nbsp;/&nbsp;&nbsp;T+<span data-site-timer>00:00:00</span></span>
</div>

<script is:inline>
  (function () {
    var KEY = 'has-session-start';
    var start;
    try {
      var saved = sessionStorage.getItem(KEY);
      start = saved ? parseInt(saved, 10) : NaN;
      if (!isFinite(start)) {
        start = Date.now();
        sessionStorage.setItem(KEY, String(start));
      }
    } catch (e) {
      start = Date.now();
    }
    var targets = document.querySelectorAll('[data-site-timer]');
    if (!targets.length) return;
    var pad = function (n) { return n < 10 ? '0' + n : String(n); };
    var tick = function () {
      var s = Math.floor((Date.now() - start) / 1000);
      if (s < 0) s = 0;
      var h = Math.floor(s / 3600);
      var m = Math.floor((s % 3600) / 60);
      var sec = s % 60;
      var out = pad(h) + ':' + pad(m) + ':' + pad(sec);
      for (var i = 0; i < targets.length; i++) targets[i].textContent = out;
    };
    tick();
    setInterval(tick, 1000);
  })();
</script>

<style is:global>
  .rail {
    position: fixed;
    top: 0; bottom: 0;
    width: 32px;
    z-index: 2;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.45em;
    text-transform: uppercase;
    color: var(--dim);
    border-left: 1px solid var(--rule);
    border-right: 1px solid var(--rule);
  }
  .rail--left { left: 0; }
  .rail--right { right: 0; }
  .rail span { writing-mode: vertical-rl; text-orientation: mixed; white-space: nowrap; }
  .rail em { color: var(--white); font-style: normal; font-weight: 600; }

  @media (max-width: 900px) {
    .rail { display: none; }
  }
</style>
