---
import type { CollectionEntry } from 'astro:content';
import HomepageLayout from '../layouts/HomepageLayout.astro';
import PostCard from './PostCard.astro';
import PaginationFooter from './PaginationFooter.astro';

export interface Props {
  pageArticles: CollectionEntry<'articles'>[];
  allArticles: CollectionEntry<'articles'>[];
  currentPage: number;
  totalPages: number;
  /* ILI-787 — index swaps the HUD logo hero for a NASA-terminal
     boot sequence that resolves into a #FFF frame block. /blog
     paginated pages keep the original HUD hero. */
  heroVariant?: 'hud' | 'frame';
  /* ILI-790 — when set, render the article-selected view at SSR
     with this slug pre-opened. Used by /blog to default to the
     latest published article without a flash of the empty
     "waiting" state on initial paint. */
  defaultOpenSlug?: string;
}

const {
  pageArticles,
  allArticles,
  currentPage,
  totalPages,
  heroVariant = 'hud',
  defaultOpenSlug,
} = Astro.props;

function formatDate(d: Date): string {
  const y = d.getUTCFullYear();
  const m = String(d.getUTCMonth() + 1).padStart(2, '0');
  const day = String(d.getUTCDate()).padStart(2, '0');
  return `${y}.${m}.${day}`;
}

const totalEntries = allArticles.length;
const entryCount = String(totalEntries).padStart(3, '0');
const lastUpdated = totalEntries > 0 ? formatDate(allArticles[0].data.date) : '—';

const rendered = await Promise.all(
  pageArticles.map(async (a) => {
    const { Content } = await a.render();
    return { article: a, Content };
  })
);

function readMinutes(body: string): number {
  const words = body.trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 220));
}

const cards = pageArticles.map((a) => ({
  slug: a.slug,
  title: a.data.title,
  date: a.data.date,
  dek: a.data.description ?? '',
  tags: a.data.tags ?? [],
  minutes: readMinutes(a.body),
  postNumber: a.data.postNumber,
}));

const articleMeta = cards.map((c) => ({
  slug: c.slug,
  title: c.title,
  lede: c.dek,
  postId: `// POST ${String(c.postNumber).padStart(2, '0')}`,
  date: formatDate(c.date),
  read: `${c.minutes} MIN READ`,
  tags: c.tags.map((t) => t.toUpperCase()),
}));

const featured = pageArticles[0] ?? allArticles[0];
const siteDescription = featured?.data.description
  ?? 'A blog about Human-Agent-System Design. Humans, agents, and systems shipping products together.';

const pageSuffix = currentPage > 1 ? ` // Page ${String(currentPage).padStart(2, '0')}` : '';
const title = `HAS Design${pageSuffix}`;

/* ILI-790 — resolve the default-open article. defaultOpenSlug
   must match an article in pageArticles so prev/next mapping
   stays consistent with the rendered list. */
const defaultOpenIdx = defaultOpenSlug
  ? pageArticles.findIndex((a) => a.slug === defaultOpenSlug)
  : -1;
const defaultOpen = defaultOpenIdx >= 0
  ? {
      idx: defaultOpenIdx,
      meta: articleMeta[defaultOpenIdx],
      prev: articleMeta[defaultOpenIdx + 1],
      next: articleMeta[defaultOpenIdx - 1],
    }
  : null;
const DefaultOpenContent = defaultOpen ? rendered[defaultOpen.idx]?.Content : null;
---
<HomepageLayout title={title} description={siteDescription} activeNav="articles">
  {defaultOpen && (
    <script is:inline data-astro-rerun>
      /* ILI-790 — when /blog renders the article-selected view at
         SSR, mark the body so SiteRails (and any other body-scoped
         open-state CSS) lands on the right state from first paint.
         No flash of the left rail before JS catches up. */
      (function () {
        try { document.body.classList.add('article-open'); } catch (e) {}
      })();
    </script>
  )}
  {defaultOpen ? null : heroVariant === 'frame' ? (
    <script is:inline data-astro-rerun>
      /* ILI-789 — pre-paint gate for the index boot sequence.
         The frame-hero scan (ILI-788) is now phase 1 of a larger
         boot that also reveals header/rail/list/footer in order.
         Adds `body.is-index-booting` (drives the four-panel mask
         and reveal stages) plus `body.has-hero-frame-play` (kept
         for the existing hero orchestrator). Conditions for play:
         - sessionStorage `has_index_booted` not set
         - sessionStorage `has_navigated_in_session` not set
           (set by HomepageLayout on astro:before-preparation —
           catches both in-app links and popstate back/forward)
         - prefers-reduced-motion off
         - performance navigation type is `navigate` or `reload`
         Otherwise the page paints in end-state with no boot. */
      (function () {
        try {
          var booted = false;
          var navigated = false;
          var heroPlayed = false;
          try {
            booted = sessionStorage.getItem('has_index_booted') === '1';
            navigated = sessionStorage.getItem('has_navigated_in_session') === '1';
            // Legacy ILI-788 flag — also set when the hero completes
            // mid-boot. Treat it as a skip signal so a reload that
            // happens after the hero ran (but before the panel reveals
            // finished) doesn't replay the whole sequence.
            heroPlayed = sessionStorage.getItem('has_hero_played') === '1';
          } catch (e) {}
          var reduced = window.matchMedia
            && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          var navType = 'navigate';
          try {
            var entries = performance.getEntriesByType('navigation');
            if (entries && entries[0] && entries[0].type) navType = entries[0].type;
          } catch (e) {}
          var coldLoad = navType === 'navigate' || navType === 'reload';
          var shouldBoot = !booted && !navigated && !heroPlayed && !reduced && coldLoad;
          if (shouldBoot) {
            document.body.classList.add('is-index-booting');
            document.body.classList.add('has-hero-frame-play');
          } else {
            document.body.classList.remove('is-index-booting');
            document.body.classList.remove('has-hero-frame-play');
          }
        } catch (e) {}
      })();
    </script>
  ) : (
    <script is:inline data-astro-rerun>
      /* ILI-781 — pre-paint sequence gate. Runs synchronously
         during HTML parsing so the body class is in place before
         the hero paints. Skip the sequence when sessionStorage
         has already seen it (subsequent visits this tab) or when
         the OS reduces motion. The orchestrator below picks the
         class up to drive the choreography; CSS scopes initial
         hidden states to it. data-astro-rerun re-evaluates on
         view transitions so navigating back to the homepage
         doesn't accidentally inherit a stale play class. */
      (function () {
        try {
          var played = false;
          try { played = sessionStorage.getItem('hero_sequence_played') === 'true'; } catch (e) {}
          var reduced = window.matchMedia
            && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          if (!played && !reduced) {
            document.body.classList.add('hero-sequence-play');
          } else {
            document.body.classList.remove('hero-sequence-play');
          }
        } catch (e) {}
      })();
    </script>
  )}
  <div
    class:list={['stage', defaultOpen && 'open']}
    id="stage"
    data-default-open-idx={defaultOpen ? String(defaultOpen.idx) : undefined}
  >
    {heroVariant === 'frame' ? (
      <div class="col col-hero has-hero-frame">
        <div class="frame-viewport" id="frame-viewport">
          <div class="scan-stack" id="scan-stack" aria-hidden="true"></div>
          <div class="frame-block" id="frame-block">
            <div class="frame-line"><div class="frame-rule" aria-hidden="true"></div></div>
            <div class="frame-line"><div class="frame-eyebrow">// FRAME &middot; V1.0 &middot; TRIAD VERIFIED</div></div>
            <div class="frame-line"><h1 class="frame-h1">Human Agent System Design</h1></div>
            <div class="frame-line"><p class="frame-dek">Humans, agents, and the system they share. Three actors. Three design objects. One framework.</p></div>
            <div class="frame-line"><div class="frame-audience">&gt; FOR THE PEOPLE SHIPPING THEM</div></div>
            <div class="frame-line"><a class="frame-cta" href="/blog">
              <span class="frame-cta-label">Begin transmission</span>
              <span class="frame-cta-arrow" aria-hidden="true">&rarr;</span>
            </a></div>
          </div>
        </div>
        <div class="signal-strip" aria-hidden="true">
          <span class="signal-item">VISITOR ACQUIRED</span>
          <span class="signal-sep">&middot;</span>
          <span class="signal-item">TELEMETRY NOMINAL</span>
          <span class="signal-sep">&middot;</span>
          <span class="signal-item">ARCHIVE STANDING BY <span class="signal-cursor">&#9646;</span></span>
          <span class="signal-sep">&middot;</span>
          <span class="signal-item">SIGNAL ██████████ 100%</span>
        </div>
        <button class="back-btn" id="back-btn" aria-label="Back to articles">
          <span class="back-content">
            <span class="back-arrow">&larr;</span>
            <span>Back</span>
          </span>
        </button>
      </div>
    ) : (
      <div class="col col-hero">
        <div class="hero-inner">
          <div class="protocol-chip" data-label="PROTOCOL 001 · PHASE ALPHA">PROTOCOL 001 &middot; PHASE ALPHA</div>

          <div class="hero-stack">
            <div class="hero-logo">
              <div class="logo-stage">
                <div class="bar full" style="top:30px;left:42px;transform:rotate(45deg)"></div>
                <div class="bar full" style="top:30px;left:115px;transform:rotate(45deg)"></div>
                <div class="bar half" style="top:81px;left:165px;transform:rotate(-45deg)"></div>
                <div class="bar half" style="top:32.6px;left:220.2px;transform:rotate(90deg)"></div>
                <div class="bar half" style="top:53.8px;left:211.4px;transform:rotate(-45deg)"></div>
                <div class="bar half" style="top:66.2px;left:253.8px;transform:rotate(-45deg)"></div>
                <div class="bar half" style="top:87.4px;left:245px;transform:rotate(90deg)"></div>
              </div>
            </div>

            <div class="hero-sub">
              <svg viewBox="0 0 275.44 15" xmlns="http://www.w3.org/2000/svg" aria-label="HUMAN AGENT SYSTEM DESIGN">
                <text x="0" y="12" font-family="'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace" font-size="13" font-weight="500" fill="currentColor" textLength="275.44" lengthAdjust="spacing">HUMAN AGENT SYSTEM DESIGN</text>
              </svg>
            </div>
          </div>

          <div class="hud-corner tl">
            <span class="hud-corner-text">
              <strong class="hud-corner-label" data-label="OBS // SITE">OBS // SITE</strong>
              <span class="hud-corner-data">
                42.56&deg;N &middot; 114.46&deg;W<br />
                <span class="dim">TWIN FALLS / IDAHO</span><br />
                <span id="hud-t">T+00:00:00</span>
              </span>
            </span>
          </div>
          <div class="hud-corner tr">
            <span class="hud-corner-text">
              <strong class="hud-corner-label" data-label="INDEX // LIVE">INDEX // LIVE</strong>
              <span class="hud-corner-data">
                ENTRIES <span id="hud-entries" data-target={totalEntries}>{entryCount}</span><br />
                UPD {lastUpdated}<br />
                <span class="dim">CH 01 / DISPATCH</span>
              </span>
            </span>
          </div>
          <div class="hud-corner bl">
            <span class="hud-corner-text">
              <strong class="hud-corner-label" data-label="STATUS // LINK">STATUS // LINK</strong>
              <span class="hud-corner-data">
                AGENT-01 &nbsp; ONLINE<br />
                OPERATOR &nbsp; LINKED<br />
                <span class="dim">HANDSHAKE &middot; OK</span>
              </span>
            </span>
          </div>
          <div class="hud-corner br">
            <span class="hud-corner-text">
              <strong class="hud-corner-label" data-label="BUILD // META">BUILD // META</strong>
              <span class="hud-corner-data">
                REV 01.00<br />
                HASH <span id="hud-hash" data-target="9F2A-8C1D">9F2A-8C1D</span><br />
                <span class="dim">GAMMA &middot; sRGB</span>
              </span>
            </span>
          </div>
        </div>
        <button class="back-btn" id="back-btn" aria-label="Back to articles">
          <span class="back-content">
            <span class="back-arrow">&larr;</span>
            <span>Back</span>
          </span>
        </button>
        <div class="hero-tooltip" id="hero-tooltip" aria-hidden="true">
          <div class="hero-tooltip-frame">
            <span class="hero-tooltip-line">
              <span class="hero-tooltip-text" data-target="> VISITOR ACQUIRED">&gt; VISITOR ACQUIRED</span>
            </span>
            <span class="hero-tooltip-line">
              <span class="hero-tooltip-text" data-target="> TELEMETRY NOMINAL">&gt; TELEMETRY NOMINAL</span>
            </span>
            <span class="hero-tooltip-line">
              <span class="hero-tooltip-text" data-target="> ARCHIVE STANDING BY">&gt; ARCHIVE STANDING BY</span>
              <span class="hero-tooltip-cursor" aria-hidden="true">&#9646;</span>
            </span>
            <span class="hero-tooltip-rule" aria-hidden="true"></span>
            <span class="hero-tooltip-line hero-tooltip-line--telem">
              <span>&gt;&nbsp;COORD&nbsp;&nbsp;</span><span id="hero-tooltip-coord">X+0000.0  Y+0000.0</span>
            </span>
            <span class="hero-tooltip-line hero-tooltip-line--telem">
              <span>&gt;&nbsp;SIGNAL&nbsp;</span><span id="hero-tooltip-signal-bar">██████████</span><span>&nbsp;</span><span id="hero-tooltip-signal-pct">100%</span>
            </span>
          </div>
        </div>
      </div>
    )}
    <div class="col col-list">
      <span class="list-label">Published Articles</span>
      <ul class="post-card-list" id="article-list">
        {cards.map((c, i) => (
          <PostCard
            index={i}
            postNumber={c.postNumber}
            slug={c.slug}
            title={c.title}
            date={c.date}
            dek={c.dek}
            tags={c.tags}
            minutes={c.minutes}
            active={defaultOpen?.idx === i}
          />
        ))}
      </ul>
      <PaginationFooter
        currentPage={currentPage}
        totalPages={totalPages}
        articleCount={totalEntries}
      />
    </div>
    <div class="col col-article">
      <button class="mobile-back" id="mobile-back" aria-label="Back to articles">
        <span>&larr;</span>
        <span>All Articles</span>
      </button>
      <article class="article-inner">
        <div class="art-head" id="art-head">
          <span class="art-head-id" id="art-head-id">{defaultOpen ? defaultOpen.meta.postId : ''}</span>
          <span class="art-head-sep" aria-hidden="true">&middot;</span>
          <span class="art-head-date" id="art-head-date">{defaultOpen ? defaultOpen.meta.date : ''}</span>
          <span class="art-head-sep" aria-hidden="true">&middot;</span>
          <span class="art-head-read" id="art-head-read">{defaultOpen ? defaultOpen.meta.read : ''}</span>
        </div>
        <h1 class="art-h1" id="art-h1">{defaultOpen ? defaultOpen.meta.title : ''}</h1>
        <p class="art-lede" id="art-lede">{defaultOpen ? defaultOpen.meta.lede : ''}</p>
        <div class="art-tags" id="art-tags">
          {defaultOpen && defaultOpen.meta.tags.length > 0
            ? `TAGS · ${defaultOpen.meta.tags.join(' · ')}`
            : ''}
        </div>
        <hr class="art-rule" aria-hidden="true" />
        <div class="art-body" id="art-body">
          {DefaultOpenContent && <DefaultOpenContent />}
        </div>
        <div class="art-end" aria-hidden="true">&middot;&nbsp;&middot;&nbsp;&middot;</div>
        <nav class="art-foot" aria-label="Article navigation">
          <button class="art-foot-btn art-foot-prev" id="art-foot-prev" type="button" hidden={!defaultOpen?.prev}>
            <span class="art-foot-dir">&larr; PREV</span>
            <span class="art-foot-title" id="art-foot-prev-title">{defaultOpen?.prev?.title ?? ''}</span>
          </button>
          <span class="art-foot-hash" id="art-foot-hash">{defaultOpen ? `#${defaultOpen.meta.slug}` : ''}</span>
          <button class="art-foot-btn art-foot-next" id="art-foot-next" type="button" hidden={!defaultOpen?.next}>
            <span class="art-foot-dir">NEXT &rarr;</span>
            <span class="art-foot-title" id="art-foot-next-title">{defaultOpen?.next?.title ?? ''}</span>
          </button>
        </nav>
      </article>
    </div>
  </div>

  <Fragment slot="after-shell">
    <div hidden aria-hidden="true">
      {rendered.map(({ article, Content }) => (
        <div id={`body-${article.slug}`}><Content /></div>
      ))}
    </div>

    <script type="application/json" id="article-meta" is:inline set:html={JSON.stringify(articleMeta)} />

    <script is:inline data-astro-rerun>
      (function () {
        var meta = [];
        try {
          meta = JSON.parse(document.getElementById('article-meta').textContent || '[]');
        } catch (e) { meta = []; }

        var stage = document.getElementById('stage');
        var items = document.querySelectorAll('.post-card');
        var backBtn = document.getElementById('back-btn');
        var mobileBack = document.getElementById('mobile-back');
        var colArticle = document.querySelector('.col-article');
        var headIdEl = document.getElementById('art-head-id');
        var headDateEl = document.getElementById('art-head-date');
        var headReadEl = document.getElementById('art-head-read');
        var h1El = document.getElementById('art-h1');
        var ledeEl = document.getElementById('art-lede');
        var tagsEl = document.getElementById('art-tags');
        var bodyEl = document.getElementById('art-body');
        var prevBtn = document.getElementById('art-foot-prev');
        var nextBtn = document.getElementById('art-foot-next');
        var prevTitleEl = document.getElementById('art-foot-prev-title');
        var nextTitleEl = document.getElementById('art-foot-next-title');
        var hashEl = document.getElementById('art-foot-hash');
        var savedScrollY = 0;
        var currentIdx = -1;

        function renderTags(tags) {
          if (!tags || !tags.length) { tagsEl.textContent = ''; return; }
          tagsEl.textContent = 'TAGS · ' + tags.join(' · ');
        }

        function renderFooter(idx) {
          var prev = meta[idx + 1];
          var next = meta[idx - 1];
          if (prev) {
            prevBtn.hidden = false;
            prevTitleEl.textContent = prev.title;
          } else {
            prevBtn.hidden = true;
            prevTitleEl.textContent = '';
          }
          if (next) {
            nextBtn.hidden = false;
            nextTitleEl.textContent = next.title;
          } else {
            nextBtn.hidden = true;
            nextTitleEl.textContent = '';
          }
          var cur = meta[idx];
          hashEl.textContent = cur ? '#' + cur.slug : '';
        }

        function openArticle(idx, opts) {
          var data = meta[idx];
          if (!data) return;
          var wasOpen = stage.classList.contains('open');
          if (!wasOpen) {
            savedScrollY = window.scrollY || window.pageYOffset || 0;
          }
          currentIdx = idx;
          headIdEl.textContent = data.postId;
          headDateEl.textContent = data.date;
          headReadEl.textContent = data.read;
          h1El.textContent = data.title;
          ledeEl.textContent = data.lede || '';
          renderTags(data.tags);
          var src = document.getElementById('body-' + data.slug);
          bodyEl.innerHTML = src ? src.innerHTML : '';
          if (window.HASReveal) {
            window.HASReveal.apply(bodyEl, {
              selectors: 'h2, h3, figure, pre, blockquote',
            });
          }
          renderFooter(idx);
          items.forEach(function (el) { el.classList.remove('active'); });
          var activeEl = items[idx];
          if (activeEl) activeEl.classList.add('active');
          stage.classList.add('open');
          document.body.classList.add('article-open');
          if (window.HASRails) {
            window.HASRails.set({
              tag: '// DISPATCH · ' + (data.postId || '').replace(/^\/\/\s*/, ''),
            });
          }
          if (!opts || opts.updateHash !== false) {
            if (history && history.replaceState) {
              history.replaceState(null, '', '#' + data.slug);
            } else {
              window.location.hash = data.slug;
            }
          }
          window.scrollTo(0, 0);
          if (colArticle) colArticle.scrollTop = 0;
        }

        function closeArticle() {
          stage.classList.remove('open');
          document.body.classList.remove('article-open');
          items.forEach(function (el) { el.classList.remove('active'); });
          currentIdx = -1;
          if (window.HASRails) window.HASRails.reset();
          if (history && history.replaceState) {
            history.replaceState(null, '', window.location.pathname + window.location.search);
          }
          window.scrollTo(0, savedScrollY);
        }

        items.forEach(function (el) {
          el.addEventListener('click', function () {
            var idx = parseInt(el.getAttribute('data-index'), 10);
            openArticle(idx);
          });
        });

        if (backBtn) backBtn.addEventListener('click', closeArticle);
        if (mobileBack) mobileBack.addEventListener('click', closeArticle);
        if (prevBtn) prevBtn.addEventListener('click', function () {
          if (currentIdx >= 0 && meta[currentIdx + 1]) openArticle(currentIdx + 1);
        });
        if (nextBtn) nextBtn.addEventListener('click', function () {
          if (currentIdx >= 0 && meta[currentIdx - 1]) openArticle(currentIdx - 1);
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') closeArticle();
        });

        var initialHash = (window.location.hash || '').replace(/^#/, '');
        if (initialHash) {
          for (var i = 0; i < meta.length; i++) {
            if (meta[i].slug === initialHash) {
              openArticle(i, { updateHash: false });
              break;
            }
          }
        } else if (stage.dataset.defaultOpenIdx) {
          /* ILI-790 — page rendered with a default-open article at SSR.
             Sync JS state to the static DOM (currentIdx + active card +
             rails tag) without re-rendering the article body, so the
             prev/next buttons and Escape-to-close still work. */
          var defaultIdx = parseInt(stage.dataset.defaultOpenIdx, 10);
          if (!isNaN(defaultIdx) && meta[defaultIdx]) {
            currentIdx = defaultIdx;
            var activeEl = items[defaultIdx];
            if (activeEl) activeEl.classList.add('active');
            if (window.HASRails) {
              window.HASRails.set({
                tag: '// DISPATCH · ' + (meta[defaultIdx].postId || '').replace(/^\/\/\s*/, ''),
              });
            }
          }
        }

        // ILI-771 — diagnostic iframe self-reports its content height so the
        // embed scales with both the article column width and inner stacking
        // (mobile single-column / desktop two-column / paragraph length).
        window.addEventListener('message', function (e) {
          var d = e.data;
          if (!d || d.type !== 'hasd-diag:height' || typeof d.height !== 'number') return;
          var frames = bodyEl.querySelectorAll('iframe');
          for (var i = 0; i < frames.length; i++) {
            if (frames[i].contentWindow === e.source) {
              frames[i].style.height = d.height + 'px';
              return;
            }
          }
        });
      })();
    </script>

    <script is:inline data-astro-rerun>
      // ILI-776 + ILI-780 — hero hover: corner-shift "lock on" +
      // mouse-following welcome tooltip with live telemetry, entry
      // scramble, blinking cursor, pulsing hairline border (CSS),
      // and occasional micro-shake. Toggles `body.hero-hover` (CSS
      // shifts the four corners inward as a unit) and translates
      // `#hero-tooltip` to trail the cursor with a small offset,
      // flipping against the viewport edges. Touch and reduced-motion
      // paths short-circuit the cursor logic; reduced-motion also
      // freezes signal fluctuation, scramble, and micro-shake.
      (function () {
        var heroCol = document.querySelector('.col-hero');
        var stage = document.getElementById('stage');
        var tooltip = document.getElementById('hero-tooltip');
        if (!heroCol || !stage || !tooltip) return;

        var frame = tooltip.querySelector('.hero-tooltip-frame');
        var coordEl = document.getElementById('hero-tooltip-coord');
        var signalBarEl = document.getElementById('hero-tooltip-signal-bar');
        var signalPctEl = document.getElementById('hero-tooltip-signal-pct');
        var textEls = tooltip.querySelectorAll('.hero-tooltip-text');

        var desktop = window.matchMedia('(min-width: 901px) and (hover: hover) and (pointer: fine)');
        var reduced = window.matchMedia('(prefers-reduced-motion: reduce)');
        var touch = window.matchMedia('(hover: none), (pointer: coarse)');

        var SCRAMBLE_CHARS = 'ABCDEFGHJKLMNPQRSTUVWXYZ0123456789';

        function fmtCoord(v) {
          var sign = v >= 0 ? '+' : '-';
          var abs = Math.abs(v);
          var whole = Math.floor(abs);
          var frac = Math.floor((abs - whole) * 10);
          var w = String(whole);
          while (w.length < 4) w = '0' + w;
          return sign + w + '.' + frac;
        }

        function setCoord(cx, cy, rect) {
          if (!coordEl) return;
          var halfW = rect.width / 2;
          var halfH = rect.height / 2;
          var nx = halfW > 0 ? ((cx - halfW) / halfW) * 1000 : 0;
          var ny = halfH > 0 ? ((halfH - cy) / halfH) * 1000 : 0;
          coordEl.textContent = 'X' + fmtCoord(nx) + '  Y' + fmtCoord(ny);
        }

        function renderSignal(value) {
          if (!signalBarEl || !signalPctEl) return;
          var pct = Math.round(value);
          var blocks = Math.round((value / 100) * 10);
          if (blocks < 7) blocks = 7;
          if (blocks > 10) blocks = 10;
          var bar = '';
          for (var i = 0; i < 10; i++) bar += i < blocks ? '█' : '░';
          signalBarEl.textContent = bar;
          var pStr = String(pct);
          if (pStr.length < 2) pStr = '0' + pStr;
          signalPctEl.textContent = pStr + '%';
        }

        // ─── Touch fallback ───────────────────────────────
        if (touch.matches) {
          tooltip.classList.add('hero-tooltip--static', 'is-visible');
          renderSignal(90);
          if (coordEl) coordEl.textContent = 'X+0000.0  Y+0000.0';
          return;
        }

        // ─── Cursor follow state ──────────────────────────
        var rafId = 0;
        var targetX = 0, targetY = 0;
        var currentX = 0, currentY = 0;
        var hasFrame = false;
        var inside = false;

        // ─── Telemetry state ──────────────────────────────
        var signalCurrent = 90;
        var signalAnimRaf = 0;
        var signalTimeout = 0;
        var shakeTimeout = 0;
        var shakeResetTimeout = 0;
        var hasScrambled = false;

        function eligible() {
          return desktop.matches && !stage.classList.contains('open');
        }

        function setStaticPosition() {
          tooltip.style.transform = '';
        }

        function tick() {
          rafId = 0;
          if (hasFrame) {
            currentX += (targetX - currentX) * 0.32;
            currentY += (targetY - currentY) * 0.32;
          } else {
            currentX = targetX;
            currentY = targetY;
            hasFrame = true;
          }
          tooltip.style.transform =
            'translate3d(' + currentX.toFixed(1) + 'px,' + currentY.toFixed(1) + 'px,0)';
          if (Math.abs(targetX - currentX) > 0.4 || Math.abs(targetY - currentY) > 0.4) {
            rafId = requestAnimationFrame(tick);
          }
        }

        function schedule() {
          if (!rafId) rafId = requestAnimationFrame(tick);
        }

        // ─── Scramble entry ───────────────────────────────
        function scrambleLine(el, target, durationMs) {
          if (!el) return;
          var start = performance.now();
          function step() {
            var elapsed = performance.now() - start;
            if (elapsed >= durationMs) { el.textContent = target; return; }
            var locked = Math.floor((elapsed / durationMs) * target.length);
            var out = '';
            for (var i = 0; i < target.length; i++) {
              var c = target.charAt(i);
              if (c === ' ' || c === '>' || c === '·') {
                out += c;
              } else if (i < locked) {
                out += c;
              } else {
                out += SCRAMBLE_CHARS.charAt(Math.floor(Math.random() * SCRAMBLE_CHARS.length));
              }
            }
            el.textContent = out;
            requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        }

        function runEntryScramble() {
          if (reduced.matches) return;
          for (var i = 0; i < textEls.length; i++) {
            (function (el, idx) {
              var target = el.getAttribute('data-target') || el.textContent || '';
              setTimeout(function () { scrambleLine(el, target, 250); }, idx * 80);
            })(textEls[i], i);
          }
        }

        // ─── Signal fluctuation ───────────────────────────
        function tickSignal() {
          var roll = Math.random();
          var target;
          if (roll < 0.08) {
            target = 78 + Math.random() * 6;       // occasional dip
          } else {
            target = 82 + Math.random() * 13;      // 82–95 nominal
          }
          var startVal = signalCurrent;
          var startT = performance.now();
          var dur = 320;
          function step() {
            if (!inside || reduced.matches) return;
            var t = (performance.now() - startT) / dur;
            if (t > 1) t = 1;
            var eased = 1 - Math.pow(1 - t, 3);
            signalCurrent = startVal + (target - startVal) * eased;
            renderSignal(signalCurrent);
            if (t < 1) signalAnimRaf = requestAnimationFrame(step);
          }
          signalAnimRaf = requestAnimationFrame(step);
          signalTimeout = window.setTimeout(tickSignal, 400 + Math.random() * 400);
        }

        function startSignal() {
          if (reduced.matches) { renderSignal(90); return; }
          stopSignal();
          tickSignal();
        }

        function stopSignal() {
          if (signalTimeout) { clearTimeout(signalTimeout); signalTimeout = 0; }
          if (signalAnimRaf) { cancelAnimationFrame(signalAnimRaf); signalAnimRaf = 0; }
        }

        // ─── Micro-shake ──────────────────────────────────
        function microShake() {
          if (!frame || reduced.matches || !inside) return;
          var dx = (Math.random() < 0.5 ? -1 : 1) * (1 + Math.random());
          var dy = (Math.random() < 0.5 ? -1 : 1) * (1 + Math.random());
          frame.style.transform =
            'translate3d(' + dx.toFixed(1) + 'px,' + dy.toFixed(1) + 'px,0)';
          shakeResetTimeout = window.setTimeout(function () {
            if (frame) frame.style.transform = '';
          }, 80);
        }

        function scheduleShake() {
          if (reduced.matches) return;
          shakeTimeout = window.setTimeout(function () {
            microShake();
            scheduleShake();
          }, 6000 + Math.random() * 4000);
        }

        function stopShake() {
          if (shakeTimeout) { clearTimeout(shakeTimeout); shakeTimeout = 0; }
          if (shakeResetTimeout) { clearTimeout(shakeResetTimeout); shakeResetTimeout = 0; }
          if (frame) frame.style.transform = '';
        }

        // ─── Lifecycle ────────────────────────────────────
        function onEnter() {
          if (!eligible()) return;
          inside = true;
          document.body.classList.add('hero-hover');
          tooltip.classList.add('is-visible');
          if (reduced.matches) {
            tooltip.classList.add('hero-tooltip--pinned');
            setStaticPosition();
          }
          if (!hasScrambled) {
            hasScrambled = true;
            runEntryScramble();
          }
          startSignal();
          scheduleShake();
        }

        function onLeave() {
          inside = false;
          document.body.classList.remove('hero-hover');
          tooltip.classList.remove('is-visible', 'hero-tooltip--pinned');
          hasFrame = false;
          if (rafId) { cancelAnimationFrame(rafId); rafId = 0; }
          stopSignal();
          stopShake();
        }

        function onMove(e) {
          if (!eligible() || !inside) return;
          var rect = heroCol.getBoundingClientRect();
          if (rect.width <= 0 || rect.height <= 0) return;
          var cx = e.clientX - rect.left;
          var cy = e.clientY - rect.top;
          setCoord(cx, cy, rect);
          if (reduced.matches) return;
          var ttW = tooltip.offsetWidth;
          var ttH = tooltip.offsetHeight;
          var pad = 8;
          var offX = 16;
          var offY = 20;
          var px = cx + offX;
          var py = cy + offY;
          if (px + ttW > rect.width - pad) px = cx - ttW - offX;
          if (py + ttH > rect.height - pad) py = cy - ttH - offY;
          if (px < pad) px = pad;
          if (py < pad) py = pad;
          targetX = px;
          targetY = py;
          schedule();
        }

        heroCol.addEventListener('mouseenter', onEnter);
        heroCol.addEventListener('mouseleave', onLeave);
        heroCol.addEventListener('mousemove', onMove);

        function onGuardChange() {
          if (!eligible()) onLeave();
        }
        desktop.addEventListener('change', onGuardChange);
        reduced.addEventListener('change', onGuardChange);

        // Seed initial readouts so the tooltip never flashes a blank
        // bar/coords on its first paint before mousemove fires.
        renderSignal(signalCurrent);
        if (coordEl) coordEl.textContent = 'X+0000.0  Y+0000.0';

        var stageObserver = new MutationObserver(function () {
          if (stage.classList.contains('open')) onLeave();
        });
        stageObserver.observe(stage, { attributes: true, attributeFilter: ['class'] });
      })();
    </script>

    <script>
      import { countUp } from '../lib/countUp';

      const prefersReducedMotion =
        typeof window !== 'undefined' &&
        typeof window.matchMedia === 'function' &&
        window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const pad = (n: number) => (n < 10 ? '0' + n : '' + n);
      const fmtT = (seconds: number) => {
        const h = Math.floor(seconds / 3600);
        const m = Math.floor((seconds % 3600) / 60);
        const s = Math.floor(seconds % 60);
        return 'T+' + pad(h) + ':' + pad(m) + ':' + pad(s);
      };

      const tEl = document.getElementById('hud-t');
      const entriesEl = document.getElementById('hud-entries');
      const hashEl = document.getElementById('hud-hash');

      // Telemetry kickoff. Default delay 80ms; when the hero
      // sequence (ILI-781) is playing, slide to stage 6 (1900ms)
      // so count-up / scramble / T+ settle alongside the bottom
      // chrome fade rather than ahead of the labels.
      const sequencePlaying =
        typeof document !== 'undefined' &&
        document.body.classList.contains('hero-sequence-play');
      const telemetryStart = sequencePlaying ? 1900 : 80;

      window.setTimeout(() => {
        if (entriesEl) {
          const target = Number(entriesEl.getAttribute('data-target') || '0');
          countUp(entriesEl, {
            from: 0,
            to: target,
            duration: 520,
            ease: 'out',
            format: (v) => String(Math.round(v)).padStart(3, '0'),
          });
        }

        if (tEl && !prefersReducedMotion) {
          const start = performance.now();
          const tick = () => {
            const elapsed = (performance.now() - start) / 1000;
            tEl.textContent = fmtT(elapsed);
          };
          tick();
          window.setInterval(tick, 1000);
        }

        if (hashEl && !prefersReducedMotion) {
          const target = hashEl.getAttribute('data-target') || '';
          const chars = 'ABCDEF0123456789';
          const duration = 600;
          const start = performance.now();
          const scramble = () => {
            const elapsed = performance.now() - start;
            if (elapsed >= duration) { hashEl.textContent = target; return; }
            const locked = Math.floor((elapsed / duration) * target.length);
            let out = '';
            for (let i = 0; i < target.length; i++) {
              if (target[i] === '-') out += '-';
              else if (i < locked) out += target[i];
              else out += chars[Math.floor(Math.random() * chars.length)];
            }
            hashEl.textContent = out;
            requestAnimationFrame(scramble);
          };
          requestAnimationFrame(scramble);
        }
      }, telemetryStart);
    </script>

    <script is:inline data-astro-rerun>
      // ILI-781 — hero sequenced reveal orchestrator.
      // The pre-paint inline gate at the top of the page added
      // `body.hero-sequence-play` if this is the first homepage
      // hit in the session and reduced-motion is off. CSS handles
      // logo blink, bracket draw-in, title clip-reveal, rail
      // cascade, and bottom-chrome fade. JS handles typewriters
      // (corner labels at stage 2, protocol chip at stage 4)
      // because they need character-by-character timing + a
      // trailing block cursor that blinks before disappearing.
      // Once stage 7 lands (~2400ms), flag sessionStorage and
      // strip the play class so further interactions paint at
      // their natural CSS state.
      (function () {
        if (!document.body.classList.contains('hero-sequence-play')) return;

        try { sessionStorage.setItem('hero_sequence_played', 'true'); } catch (e) {}

        var CURSOR_BLINK_MS = 900;     // ~2 cycles at 0.6s steps
        var labels = [
          { el: document.querySelector('.hud-corner.tl .hud-corner-label'), start: 500 },
          { el: document.querySelector('.hud-corner.tr .hud-corner-label'), start: 580 },
          { el: document.querySelector('.hud-corner.bl .hud-corner-label'), start: 660 },
          { el: document.querySelector('.hud-corner.br .hud-corner-label'), start: 740 },
        ];
        var chip = document.querySelector('.protocol-chip');

        function typewriter(el, text, durationMs, onDone) {
          if (!el) { if (onDone) onDone(); return; }
          el.classList.add('is-typing');
          el.textContent = '';
          var cursor = document.createElement('span');
          cursor.className = 'seq-cursor';
          cursor.setAttribute('aria-hidden', 'true');
          cursor.textContent = '▮';
          el.appendChild(cursor);
          var len = text.length;
          if (len === 0) {
            el.classList.remove('is-typing');
            el.classList.add('is-typed');
            if (onDone) onDone();
            return;
          }
          var perChar = Math.max(8, Math.floor(durationMs / len));
          var i = 0;
          function step() {
            i += 1;
            // Re-render: typed prefix + cursor.
            while (el.firstChild && el.firstChild !== cursor) {
              el.removeChild(el.firstChild);
            }
            el.insertBefore(document.createTextNode(text.slice(0, i)), cursor);
            if (i < len) {
              window.setTimeout(step, perChar);
            } else {
              el.classList.remove('is-typing');
              el.classList.add('is-typed');
              window.setTimeout(function () {
                if (cursor.parentNode === el) el.removeChild(cursor);
                if (onDone) onDone();
              }, CURSOR_BLINK_MS);
            }
          }
          window.setTimeout(step, perChar);
        }

        labels.forEach(function (item) {
          if (!item.el) return;
          var label = item.el.getAttribute('data-label') || item.el.textContent || '';
          // Pre-empty so the label doesn't flash its full text
          // before the timed start. CSS visibility:hidden hides
          // it, but emptying also avoids any text-metrics shift
          // during the typewriter pass.
          item.el.textContent = '';
          window.setTimeout(function () {
            typewriter(item.el, label, 200);
          }, item.start);
        });

        if (chip) {
          var chipText = chip.getAttribute('data-label') || chip.textContent || '';
          chip.textContent = '';
          window.setTimeout(function () {
            typewriter(chip, chipText, 300);
          }, 1100);
        }

        // Stage 7 — clear the play class so any subsequent
        // re-entry to this script (view transitions) finds the
        // hero in its natural rest state. The sessionStorage
        // flag set above already gates re-runs.
        window.setTimeout(function () {
          document.body.classList.remove('hero-sequence-play');
        }, 2500);
      })();
    </script>

    <script is:inline data-astro-rerun>
      /* ILI-788 — frame-hero boot sequence orchestrator.
         One continuous terminal print pass at a single rhythm:
         13 scan lines at 145ms cadence after a 280ms initial
         delay, then a 280ms hand-off pause, scan-stack fades
         out as frame-block becomes visible, then a 200ms breath
         before frame lines (rule, eyebrow, h1, dek, audience,
         cta) print at the same 145ms cadence using the same
         max-height + opacity reveal as scan lines. Set
         sessionStorage so within-session repeat visits skip
         straight to end-state via the pre-paint gate. */
      (function () {
        if (!document.body.classList.contains('has-hero-frame-play')) return;
        var hero = document.querySelector('.col-hero.has-hero-frame');
        if (!hero) return;
        var scanStack = hero.querySelector('.scan-stack');
        var frameBlock = hero.querySelector('.frame-block');
        if (!scanStack || !frameBlock) return;

        var lines = [
          ['+00.001', 'PING', 'sweep envelope · radius ∞'],
          ['+00.034', 'CAL',  'calibrating actor classifier'],
          ['+00.124', 'HIT',  'actor.01 · classification HUMAN'],
          ['+00.298', 'HIT',  'actor.02 · classification AGENT'],
          ['+00.412', 'PING', 'third-actor sweep · expanded radius'],
          ['+00.620', 'PING', 'sweep · negative'],
          ['+00.840', 'NULL', 'no signal · system not located'],
          ['+01.020', 'WARN', 'triad incomplete · reclassifying'],
          ['+01.180', 'NOTE', 'environment is not substrate'],
          ['+01.340', 'RECL', 'classifier · revising'],
          ['+01.488', 'HIT',  'actor.03 · classification SYSTEM'],
          ['+01.604', 'LOCK', 'triad established · 3 design objects'],
          ['+01.660', 'RDY',  'publishing frame · v1.0']
        ];

        var INITIAL_DELAY = 280;
        var CADENCE = 145;
        var HANDOFF_PAUSE = 280;
        var FRAME_BREATH = 200;

        function makeLine(parts) {
          var el = document.createElement('div');
          el.className = 'scan-line';
          var t = document.createElement('span'); t.className = 'scan-t'; t.textContent = parts[0];
          var c = document.createElement('span'); c.className = 'scan-c'; c.textContent = parts[1];
          var d = document.createElement('span'); d.className = 'scan-d'; d.textContent = parts[2];
          el.appendChild(t); el.appendChild(c); el.appendChild(d);
          return el;
        }

        // Pre-build the scan-line elements so layout doesn't shift
        // mid-sequence; reveal each via a class flip.
        var nodes = lines.map(function (parts) {
          var n = makeLine(parts);
          scanStack.appendChild(n);
          return n;
        });

        nodes.forEach(function (el, i) {
          window.setTimeout(function () {
            el.classList.add('is-visible');
          }, INITIAL_DELAY + i * CADENCE);
        });

        // Frame phase: 280ms hand-off pause + 200ms breath after
        // the last scan line, then each .frame-line prints at the
        // same 145ms cadence. Same reveal mechanism as scan lines
        // (max-height + opacity, no translateY) so the entire pass
        // reads as one rhythm. The scan log stays visible — frame
        // lines print below it and the whole stack lifts together.
        var totalLinesTime = INITIAL_DELAY + (nodes.length - 1) * CADENCE;
        var frameStart = totalLinesTime + HANDOFF_PAUSE + FRAME_BREATH;
        var frameLines = frameBlock.querySelectorAll('.frame-line');
        frameLines.forEach(function (el, i) {
          window.setTimeout(function () {
            el.classList.add('is-visible');
          }, frameStart + i * CADENCE);
        });

        // Post-completion: set the session flag and drop the play
        // class so any re-entry from a view transition lands on
        // end-state rules (no transitions re-running).
        var lastFrameAt = frameStart + Math.max(0, frameLines.length - 1) * CADENCE;
        var totalDuration = lastFrameAt + 400;
        window.setTimeout(function () {
          try { sessionStorage.setItem('has_hero_played', '1'); } catch (e) {}
          document.body.classList.remove('has-hero-frame-play');
        }, totalDuration);
      })();
    </script>

    <script is:inline data-astro-rerun>
      /* ILI-789 — index boot orchestrator. Phase 1 (the frame
