---
interface Props {
  activeNav?: 'articles' | 'framework' | 'glossary' | 'design-system' | 'diagnostic' | 'reading-list' | 'system-recipes' | 'about' | 'contact';
}

const { activeNav = 'articles' } = Astro.props;
const isFrameworkActive = activeNav === 'framework';
const isResourcesActive =
  activeNav === 'glossary' ||
  activeNav === 'design-system' ||
  activeNav === 'diagnostic' ||
  activeNav === 'reading-list' ||
  activeNav === 'system-recipes';
---
<header class="site-header">
  <div class="sh-mark">
    <a href="/" class="sh-logo" aria-label="HAS Design home">
      <div class="logo-stage">
        <div class="bar full" style="top:30px;left:42px;transform:rotate(45deg)"></div>
        <div class="bar full" style="top:30px;left:115px;transform:rotate(45deg)"></div>
        <div class="bar half" style="top:81px;left:165px;transform:rotate(-45deg)"></div>
        <div class="bar half" style="top:32.6px;left:220.2px;transform:rotate(90deg)"></div>
        <div class="bar half" style="top:53.8px;left:211.4px;transform:rotate(-45deg)"></div>
        <div class="bar half" style="top:66.2px;left:253.8px;transform:rotate(-45deg)"></div>
        <div class="bar half" style="top:87.4px;left:245px;transform:rotate(90deg)"></div>
      </div>
    </a>
    <span class="sh-dot" aria-hidden="true"></span>
    <span class="sh-name">ONLINE</span>
  </div>

  <nav class="nav">
    <a href="/blog" aria-current={activeNav === 'articles' ? 'page' : undefined}>Articles</a>

    <div class="nav-dropdown" data-nav-dropdown>
      <button
        class="nav-dropdown-trigger"
        type="button"
        aria-expanded="false"
        aria-haspopup="menu"
        aria-controls="nav-framework-panel"
        aria-current={isFrameworkActive ? 'page' : undefined}
        data-nav-dropdown-trigger
      >
        <span>Framework</span>
        <span class="nav-dropdown-chevron" aria-hidden="true">▾</span>
      </button>
      <div
        class="nav-dropdown-panel"
        id="nav-framework-panel"
        role="menu"
        data-nav-dropdown-panel
      >
        <a href="/axioms" role="menuitem">Axioms</a>
        <a href="/constraints" role="menuitem">Constraints</a>
        <a href="/design-requirements" role="menuitem">Design Requirements</a>
      </div>
    </div>

    <div class="nav-dropdown" data-nav-dropdown>
      <button
        class="nav-dropdown-trigger"
        type="button"
        aria-expanded="false"
        aria-haspopup="menu"
        aria-controls="nav-resources-panel"
        aria-current={isResourcesActive ? 'page' : undefined}
        data-nav-dropdown-trigger
      >
        <span>Resources</span>
        <span class="nav-dropdown-chevron" aria-hidden="true">▾</span>
      </button>
      <div
        class="nav-dropdown-panel"
        id="nav-resources-panel"
        role="menu"
        data-nav-dropdown-panel
      >
        <a href="/glossary" role="menuitem" aria-current={activeNav === 'glossary' ? 'page' : undefined}>Glossary</a>
        <a href="/design-system" role="menuitem" aria-current={activeNav === 'design-system' ? 'page' : undefined}>Design System</a>
        <a href="/diagnostic" role="menuitem" aria-current={activeNav === 'diagnostic' ? 'page' : undefined}>Diagnostic</a>
        <a href="/reading-list" role="menuitem" aria-current={activeNav === 'reading-list' ? 'page' : undefined}>Reading List</a>
        <a href="/system-recipes" role="menuitem" aria-current={activeNav === 'system-recipes' ? 'page' : undefined}>System Recipes</a>
      </div>
    </div>

    <a href="/about" aria-current={activeNav === 'about' ? 'page' : undefined}>About</a>
    <a href="/contact" aria-current={activeNav === 'contact' ? 'page' : undefined}>Contact</a>
  </nav>

  <button class="sh-burger" type="button" aria-label="Open menu" aria-expanded="false" aria-controls="sh-drawer" data-sh-burger>
    <span class="sh-burger-line"></span>
    <span class="sh-burger-line"></span>
    <span class="sh-burger-line"></span>
  </button>
</header>

<div class="sh-drawer" id="sh-drawer" data-sh-drawer>
  <div class="sh-drawer-backdrop" data-sh-close></div>
  <div class="sh-drawer-panel">
    <div class="sh-drawer-mark" aria-hidden="true">
      <div class="sh-drawer-logo">
        <div class="logo-stage">
          <div class="bar full" style="top:30px;left:42px;transform:rotate(45deg)"></div>
          <div class="bar full" style="top:30px;left:115px;transform:rotate(45deg)"></div>
          <div class="bar half" style="top:81px;left:165px;transform:rotate(-45deg)"></div>
          <div class="bar half" style="top:32.6px;left:220.2px;transform:rotate(90deg)"></div>
          <div class="bar half" style="top:53.8px;left:211.4px;transform:rotate(-45deg)"></div>
          <div class="bar half" style="top:66.2px;left:253.8px;transform:rotate(-45deg)"></div>
          <div class="bar half" style="top:87.4px;left:245px;transform:rotate(90deg)"></div>
        </div>
      </div>
      <div class="sh-drawer-tagline">
        <svg viewBox="0 0 275.44 15" xmlns="http://www.w3.org/2000/svg" aria-label="HUMAN AGENT SYSTEM DESIGN">
          <text x="0" y="12" font-family="'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace" font-size="13" font-weight="500" fill="currentColor" textLength="275.44" lengthAdjust="spacing">HUMAN AGENT SYSTEM DESIGN</text>
        </svg>
      </div>
    </div>
    <nav
      class="sh-drawer-nav"
      aria-label="Primary"
    >
      <a href="/blog" data-text="Articles" aria-current={activeNav === 'articles' ? 'page' : undefined}>Articles</a>

      <div
        class="sh-drawer-dropdown"
        data-mobile-dropdown
        data-dropdown-active={isFrameworkActive ? 'true' : 'false'}
      >
        <button
          class="sh-drawer-dropdown-trigger"
          type="button"
          aria-expanded={isFrameworkActive ? 'true' : 'false'}
          aria-controls="sh-drawer-framework-children"
          aria-current={isFrameworkActive ? 'page' : undefined}
          data-text="Framework"
          data-mobile-dropdown-trigger
        >
          <span class="link-typed">Framework</span>
          <span class="sh-drawer-dropdown-chevron" aria-hidden="true">▾</span>
        </button>
        <div
          class="sh-drawer-dropdown-children"
          id="sh-drawer-framework-children"
          data-mobile-dropdown-children
        >
          <a href="/axioms" data-text="Axioms" data-dropdown-child>Axioms</a>
          <a href="/constraints" data-text="Constraints" data-dropdown-child>Constraints</a>
          <a href="/design-requirements" data-text="Design Requirements" data-dropdown-child>Design Requirements</a>
        </div>
      </div>

      <div
        class="sh-drawer-dropdown"
        data-mobile-dropdown
        data-dropdown-active={isResourcesActive ? 'true' : 'false'}
      >
        <button
          class="sh-drawer-dropdown-trigger"
          type="button"
          aria-expanded={isResourcesActive ? 'true' : 'false'}
          aria-controls="sh-drawer-resources-children"
          aria-current={isResourcesActive ? 'page' : undefined}
          data-text="Resources"
          data-mobile-dropdown-trigger
        >
          <span class="link-typed">Resources</span>
          <span class="sh-drawer-dropdown-chevron" aria-hidden="true">▾</span>
        </button>
        <div
          class="sh-drawer-dropdown-children"
          id="sh-drawer-resources-children"
          data-mobile-dropdown-children
        >
          <a href="/glossary" data-text="Glossary" data-dropdown-child aria-current={activeNav === 'glossary' ? 'page' : undefined}>Glossary</a>
          <a href="/design-system" data-text="Design System" data-dropdown-child aria-current={activeNav === 'design-system' ? 'page' : undefined}>Design System</a>
          <a href="/diagnostic" data-text="Diagnostic" data-dropdown-child aria-current={activeNav === 'diagnostic' ? 'page' : undefined}>Diagnostic</a>
          <a href="/reading-list" data-text="Reading List" data-dropdown-child aria-current={activeNav === 'reading-list' ? 'page' : undefined}>Reading List</a>
          <a href="/system-recipes" data-text="System Recipes" data-dropdown-child aria-current={activeNav === 'system-recipes' ? 'page' : undefined}>System Recipes</a>
        </div>
      </div>

      <a href="/about" data-text="About" aria-current={activeNav === 'about' ? 'page' : undefined}>About</a>
      <a href="/contact" data-text="Contact" aria-current={activeNav === 'contact' ? 'page' : undefined}>Contact</a>
    </nav>
  </div>
</div>

<script is:inline data-astro-rerun>
  // Mobile shrink-on-scroll. Header collapses to half height once the user
  // has scrolled past the header itself; restores when they scroll up by
  // 20px cumulative (or return near the top). Desktop is a no-op because
  // the .is-condensed CSS only kicks in under the 900px media query.
  (function () {
    if (window.__shScrollMounted) return;
    window.__shScrollMounted = true;
    var COLLAPSE_AFTER = 80;   // px scrolled before condensing
    var EXPAND_BY = 20;        // px of upward travel needed to expand again
    var COLLAPSE_DELTA = 40;   // header height shrinks 80 → 40 on condense
    // Two-frame momentum recoil during a downward fling (e.g. scroll-deltas
    // like +5,+5,-12,-15) used to total > EXPAND_BY across two frames and
    // bounced the header off, then the next +5 re-condensed it — flutter.
    // Require either a single decisive upward delta (≥ EXPAND_BY in one
    // frame, the discrete-jump case the test hits) OR sustained upward
    // motion across this many consecutive frames before honoring upAccum.
    var SUSTAINED_UP_FRAMES = 3;
    var lastY = window.scrollY || 0;
    var upAccum = 0;
    var upFrames = 0;
    var ticking = false;

    // Refuse to condense when the page is barely taller than the viewport.
    // Condensing shrinks the document by COLLAPSE_DELTA, which can clamp
    // scrollY below the y < 8 reset threshold — header expands, page grows,
    // user scrolls again, repeat: flutter. Only condense when there's
    // enough room to stay scrolled past the reset threshold afterward.
    // Homepage triggered this; article/glossary have plenty of body length.
    function hasRoomToCondense(currentY) {
      var docHeight = document.documentElement.scrollHeight;
      var viewportHeight = window.innerHeight;
      var postCondenseMaxScroll = (docHeight - COLLAPSE_DELTA) - viewportHeight;
      return postCondenseMaxScroll >= currentY;
    }

    function apply() {
      ticking = false;
      var root = document.documentElement;
      var y = window.scrollY || 0;
      var dy = y - lastY;
      lastY = y;

      if (y < 8) {
        root.classList.remove('sh-condensed');
        upAccum = 0;
        upFrames = 0;
        return;
      }
      if (dy > 0) {
        upAccum = 0;
        upFrames = 0;
        if (y > COLLAPSE_AFTER && hasRoomToCondense(y)) {
          root.classList.add('sh-condensed');
        }
      } else if (dy < 0) {
        upAccum += -dy;
        upFrames += 1;
        var decisive = -dy >= EXPAND_BY;
        if (upAccum >= EXPAND_BY && (decisive || upFrames >= SUSTAINED_UP_FRAMES)) {
          root.classList.remove('sh-condensed');
          upAccum = 0;
          upFrames = 0;
        }
      }
    }
    function onScroll() {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(apply);
    }
    window.addEventListener('scroll', onScroll, { passive: true });
  })();

  // Desktop nav dropdowns (Framework, Resources) — click to open, outside
  // click / Escape to close, ↓ to move into panel. Opening one closes any
  // other open dropdown so the two never overlap.
  (function () {
    var wraps = document.querySelectorAll('[data-nav-dropdown]');
    if (!wraps.length) return;

    function setupOne(wrap) {
      var trigger = wrap.querySelector('[data-nav-dropdown-trigger]');
      var panel = wrap.querySelector('[data-nav-dropdown-panel]');
      if (!trigger || !panel) return;
      var items = panel.querySelectorAll('a');

      function isOpen() { return wrap.classList.contains('is-open'); }
      function open() {
        wraps.forEach(function (other) {
          if (other === wrap) return;
          other.classList.remove('is-open');
          var otherTrigger = other.querySelector('[data-nav-dropdown-trigger]');
          if (otherTrigger) otherTrigger.setAttribute('aria-expanded', 'false');
        });
        wrap.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
      }
      function close(returnFocus) {
        wrap.classList.remove('is-open');
        trigger.setAttribute('aria-expanded', 'false');
        if (returnFocus) trigger.focus();
      }

      trigger.addEventListener('click', function (e) {
        e.stopPropagation();
        if (isOpen()) close(false); else open();
      });

      trigger.addEventListener('keydown', function (e) {
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          if (!isOpen()) open();
          if (items[0]) items[0].focus();
        } else if (e.key === 'Escape' && isOpen()) {
          e.preventDefault();
          close(true);
        }
      });

      panel.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && isOpen()) {
          e.preventDefault();
          close(true);
        } else if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
          e.preventDefault();
          var idx = -1;
          for (var i = 0; i < items.length; i++) {
            if (items[i] === document.activeElement) { idx = i; break; }
          }
          var next = e.key === 'ArrowDown' ? idx + 1 : idx - 1;
          if (next < 0) next = items.length - 1;
          if (next >= items.length) next = 0;
          items[next].focus();
        }
      });

      document.addEventListener('click', function (e) {
        if (!isOpen()) return;
        if (wrap.contains(e.target)) return;
        close(false);
      });

      document.addEventListener('focusin', function (e) {
        if (!isOpen()) return;
        if (wrap.contains(e.target)) return;
        close(false);
      });
    }

    wraps.forEach(setupOne);
  })();

  (function () {
    var burger = document.querySelector('[data-sh-burger]');
    var drawer = document.querySelector('[data-sh-drawer]');
    if (!burger || !drawer) return;
    // Reset condensed state on page transition so a deep-scrolled article
    // doesn't leave the next page with a half header before the user scrolls.
    document.documentElement.classList.remove('sh-condensed');
    // Re-running after a view transition can leave html overflow stuck
    // hidden if the previous page was unloaded with the drawer open.
    document.documentElement.style.overflow = '';
    var dropdowns = [];
    drawer.querySelectorAll('[data-mobile-dropdown]').forEach(function (wrap) {
      var trigger = wrap.querySelector('[data-mobile-dropdown-trigger]');
      var children = wrap.querySelector('[data-mobile-dropdown-children]');
      if (!trigger || !children) return;
      dropdowns.push({
        wrap: wrap,
        trigger: trigger,
        children: children,
        childLinks: wrap.querySelectorAll('[data-dropdown-child]'),
        active: wrap.getAttribute('data-dropdown-active') === 'true',
      });
    });
    var closers = drawer.querySelectorAll('[data-sh-close], a');
    var STEP_MS = 22;       // per-char interval
    var GAP_MS = 60;        // pause between items
    var typeTimers = [];

    function setMobileDropdownOpen(dd, isOpen) {
      if (!dd) return;
      dd.wrap.classList.toggle('is-open', isOpen);
      dd.trigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
    }
    function findDropdownByTrigger(trigger) {
      for (var i = 0; i < dropdowns.length; i++) {
        if (dropdowns[i].trigger === trigger) return dropdowns[i];
      }
      return null;
    }

    function clearTypeTimers() {
      typeTimers.forEach(function (id) { window.clearTimeout(id); });
      typeTimers = [];
    }

    // Build the typewriter sequence. Top-level rows always type. Dropdown
    // children only type when their accordion is initially expanded — i.e.
    // when the current route is inside that dropdown.
    function getTypeSequence() {
      var rows = drawer.querySelectorAll('.sh-drawer-nav > a, [data-mobile-dropdown-trigger]');
      var seq = [];
      rows.forEach(function (row) {
        seq.push(row);
        if (row.hasAttribute('data-mobile-dropdown-trigger')) {
          var dd = findDropdownByTrigger(row);
          if (dd && dd.active) {
            dd.childLinks.forEach(function (child) { seq.push(child); });
          }
        }
      });
      return seq;
    }

    // Restore an element to its full data-text label without animation.
    // Anchors use a span.link-typed structure; the resources trigger
    // already wraps its label in .link-typed via the template.
    function restoreLink(el) {
      var text = el.dataset.text || '';
      var typed = el.querySelector('.link-typed');
      if (typed) {
        typed.textContent = text;
      } else {
        el.textContent = text;
      }
      el.classList.remove('is-typing');
      el.classList.remove('is-typed');
    }

    function typeLinks() {
      var seq = getTypeSequence();
      // Empty every sequenced row + scaffold cursor. Rows outside the
      // sequence (e.g. collapsed accordion children) are restored to
      // their static text so they're ready when the user expands.
      seq.forEach(function (el) {
        el.classList.remove('is-typing');
        el.classList.remove('is-typed');
        var typed = el.querySelector('.link-typed');
        if (!typed) {
          el.innerHTML = '<span class="link-typed"></span><span class="link-cursor" aria-hidden="true"></span>';
        } else {
          typed.textContent = '';
          if (!el.querySelector('.link-cursor')) {
            var cursor = document.createElement('span');
            cursor.className = 'link-cursor';
            cursor.setAttribute('aria-hidden', 'true');
            el.appendChild(cursor);
          }
        }
      });
      dropdowns.forEach(function (dd) {
        dd.childLinks.forEach(function (child) {
          if (seq.indexOf(child) === -1) restoreLink(child);
        });
      });

      function typeOne(idx) {
        if (idx >= seq.length) return;
        var el = seq[idx];
        var text = el.dataset.text || '';
        var typed = el.querySelector('.link-typed');
        el.classList.add('is-typing');
        var i = 0;
        function tick() {
          i += 1;
          typed.textContent = text.slice(0, i);
          if (i < text.length) {
            typeTimers.push(window.setTimeout(tick, STEP_MS));
          } else {
            el.classList.remove('is-typing');
            el.classList.add('is-typed');
            typeTimers.push(window.setTimeout(function () { typeOne(idx + 1); }, GAP_MS));
          }
        }
        tick();
      }
      typeOne(0);
    }

    function resetLinks() {
      clearTypeTimers();
      var allRows = drawer.querySelectorAll('.sh-drawer-nav a, [data-mobile-dropdown-trigger]');
      allRows.forEach(function (el) { restoreLink(el); });
    }

    function open() {
      drawer.classList.add('is-open');
      burger.classList.add('is-open');
      burger.setAttribute('aria-expanded', 'true');
      document.documentElement.style.overflow = 'hidden';
      // Each menu open: each accordion starts collapsed unless the route
      // is inside it, in which case it auto-expands.
      dropdowns.forEach(function (dd) {
        setMobileDropdownOpen(dd, dd.active);
      });
      typeTimers.push(window.setTimeout(typeLinks, 80));
    }
    function close() {
      drawer.classList.remove('is-open');
      burger.classList.remove('is-open');
      burger.setAttribute('aria-expanded', 'false');
      document.documentElement.style.overflow = '';
      window.setTimeout(function () {
        if (!drawer.classList.contains('is-open')) resetLinks();
      }, 280);
    }
    burger.addEventListener('click', function () {
      if (drawer.classList.contains('is-open')) close(); else open();
    });
    closers.forEach(function (el) { el.addEventListener('click', close); });
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && drawer.classList.contains('is-open')) close();
    });

    dropdowns.forEach(function (dd) {
      dd.trigger.addEventListener('click', function () {
        var willOpen = !dd.wrap.classList.contains('is-open');
        // When the user expands mid-session, restore child labels so they
        // render immediately (no typewriter — that's reserved for the
        // initial open animation).
        if (willOpen) {
          dd.childLinks.forEach(function (child) { restoreLink(child); });
        }
        setMobileDropdownOpen(dd, willOpen);
      });
    });
  })();
</script>

<style is:global>
  :root { --header-h: 80px; }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 32px;
    height: var(--header-h);
    padding: 0 2.5rem;
    background: var(--black);
    border-bottom: 1px solid var(--rule);
    transition: height var(--dur-fast) var(--ease-out);
  }

  .site-header .sh-mark {
    display: flex;
    align-items: center;
    gap: 14px;
    min-width: 0;
  }
  .site-header a { color: inherit; text-decoration: none; }

  .site-header .sh-logo {
    width: 63px;
    height: 27px;
    overflow: hidden;
    position: relative;
    flex-shrink: 0;
    display: block;
  }
  .site-header .sh-logo .logo-stage {
    position: relative;
    width: 420px;
    height: 180px;
    transform: scale(0.15);
    transform-origin: top left;
  }
  .site-header .sh-logo .bar { position: absolute; background: var(--white); }
  .site-header .sh-logo .full {
    width: 30px; height: 120px;
    clip-path: polygon(50% 0%, 100% 12.5%, 100% 87.5%, 50% 100%, 0% 87.5%, 0% 12.5%);
  }
  .site-header .sh-logo .half {
    width: 30px; height: 60px;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
  }

  .site-header .sh-dot {
    width: 7px;
    height: 7px;
    background: var(--white);
    border-radius: 50%;
    box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.06),
      0 0 12px rgba(255, 255, 255, 0.35);
    animation: pulse 2.2s ease-in-out infinite;
    flex-shrink: 0;
  }

  .site-header .sh-name {
    color: var(--mid);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 300;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .site-header .nav {
    display: flex;
    gap: 2rem;
    justify-self: end;
    align-items: center;
  }
  .site-header .nav a,
  .site-header .nav-dropdown-trigger {
    font-family: var(--font-mono);
    font-weight: 500;
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--mid);
    white-space: nowrap;
    padding: 6px 0;
    border-bottom: 1px solid transparent;
    transition:
      color var(--dur-fast) var(--ease-out),
      border-color var(--dur-fast) var(--ease-out);
  }
  .site-header .nav-dropdown-trigger {
    background: transparent;
    border-top: none;
    border-left: none;
    border-right: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin: 0;
  }
  .site-header .nav a:where(:hover, :focus-visible),
  .site-header .nav-dropdown-trigger:where(:hover, :focus-visible) {
    color: var(--white);
    border-bottom-color: var(--white);
  }
  .site-header .nav a[aria-current="page"],
  .site-header .nav-dropdown-trigger[aria-current="page"] {
    color: var(--white);
    border-bottom-color: var(--white);
  }
  .site-header .nav a:focus-visible,
  .site-header .nav-dropdown-trigger:focus-visible {
    outline: none;
  }

  /* Nav dropdown (Framework, Resources) */
  .site-header .nav-dropdown {
    position: relative;
    display: inline-flex;
  }
  .site-header .nav-dropdown-chevron {
    display: inline-block;
    line-height: 1;
    transform: translateY(-1px) rotate(0deg);
    transition: transform var(--dur-fast) var(--ease-out);
