---
/* HUD post card — spec-sheet look.
   Mono // POST NN id + date header, Lato 700 title, dek,
   mono tag + read-time footer. Hairline border brighten on
   hover. See ILI-721. Pure vw desktop / px mobile typography
   per CLAUDE.md non-negotiables. */
import CategoryBadge from './CategoryBadge.astro';
import type { CategorySlug } from '../lib/has-framework';

export interface Props {
  index: number;
  postNumber: number;
  slug: string;
  title: string;
  date: Date;
  dek?: string;
  minutes: number;
  active?: boolean;
  category?: CategorySlug;
}

const { index, postNumber, slug, title, date, dek, minutes, active = false, category } = Astro.props;

function formatDate(d: Date): string {
  const y = d.getUTCFullYear();
  const m = String(d.getUTCMonth() + 1).padStart(2, '0');
  const day = String(d.getUTCDate()).padStart(2, '0');
  return `${y}.${m}.${day}`;
}

const idLabel = `// POST ${String(postNumber).padStart(2, '0')}`;
const dateLabel = formatDate(date);
const readLabel = `${minutes} MIN READ`;
---
<li class:list={['post-card reveal', active && 'active']} data-index={index} data-slug={slug} style={`--reveal-i: ${index}`}>
  <div class="post-card-top">
    <span class="post-card-id">{idLabel}</span>
    <span class="post-card-date">{dateLabel}</span>
  </div>

  <div class="post-card-body">
    <div class="post-card-title">{title}</div>
    {dek && <div class="post-card-dek">{dek}</div>}
  </div>

  <div class="post-card-foot">
    <span class="post-card-tags">
      {category && <CategoryBadge category={category} linkToHub={false} />}
    </span>
    <span class="post-card-read">
      <span>{readLabel}</span>
      <span class="arrow" aria-hidden="true">&rarr;</span>
    </span>
  </div>
</li>
