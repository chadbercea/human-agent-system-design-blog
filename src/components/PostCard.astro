---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  variant?: 'lead' | 'secondary' | 'brief' | 'tile' | 'default';
  gridClass?: string;
  animateIn?: boolean;
}

const { post, variant = 'default', gridClass, animateIn = false } = Astro.props;
const sectionLabel = post.data.tags.length > 0 ? post.data.tags[0] : null;
---

<li class:list={[
  variant === 'lead' && 'paper-card paper-card--lead border border-border p-6 min-h-0',
  variant === 'secondary' && 'paper-card paper-card--secondary border border-border p-4 min-h-0',
  variant === 'brief' && 'paper-card paper-card--brief border border-border p-3 min-h-0',
  variant === 'tile' && 'paper-card paper-card--tile border border-border p-4 min-h-0',
  variant === 'default' && 'border-b border-border py-6 first:pt-0 last:border-0',
  gridClass
]} data-animate-in={animateIn ? 'true' : undefined}>
  <a href={`/${post.slug}`} class="block group link-block card-link h-full flex flex-col">
    {variant !== 'brief' && sectionLabel && (
      <span class="paper-section-label block mb-2">{sectionLabel}</span>
    )}
    <time datetime={post.data.publishDate.toISOString()} class="card-meta block mb-2">
      {post.data.publishDate.toLocaleDateString('en-CA', {
        year: 'numeric',
        month: (variant === 'tile' || variant === 'brief') ? 'short' : 'long',
        day: 'numeric',
      })}
    </time>
    <span class:list={[
      'text-text block group-hover:text-accent flex-1',
      variant === 'lead' && 'card-title-lead',
      variant === 'secondary' && 'card-title-secondary',
      variant === 'brief' && 'card-title-brief',
      variant === 'tile' && 'card-title-tile',
      variant === 'default' && 'card-title-default',
    ]}>{post.data.title}</span>
    {(variant === 'lead' || variant === 'secondary') && post.data.author && (
      <span class="card-byline block mt-1">By {post.data.author}</span>
    )}
    {(variant === 'lead' || variant === 'secondary') && post.data.description && (
      <p class="paper-deck mt-2">{post.data.description}</p>
    )}
    {variant === 'lead' && post.data.tags.length > 0 && (
      <ul class="list-none p-0 m-0 flex flex-wrap gap-x-3 gap-y-1 mt-2 card-meta">
        {post.data.tags.map((tag) => (
          <li>{tag}</li>
        ))}
      </ul>
    )}
  </a>
</li>
