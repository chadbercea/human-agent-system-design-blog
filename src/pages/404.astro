---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="The page you are looking for does not exist.">
  <article>
    <p class="font-mono text-xs text-text-muted uppercase tracking-wider mb-2">404</p>
    <h1 class="text-4xl sm:text-5xl font-bold text-text mb-4 tracking-tight">Page not found</h1>
    <p class="text-text-muted mb-8">The page you are looking for does not exist or has been moved.</p>
    <a href="/" class="text-accent no-underline hover:underline">Back to blog</a>
  </article>
</BaseLayout>
