---
import HubLayout from '../../layouts/HubLayout.astro';
import { getAllCategories, type CategorySlug } from '../../lib/has-framework';

export async function getStaticPaths() {
  const categories = await getAllCategories();
  return categories.map((c) => ({ params: { category: c.data.slug } }));
}

const { category } = Astro.params as { category: CategorySlug };
---

<HubLayout category={category} />
