---
import { readFileSync } from 'node:fs';
import path from 'node:path';
import { getCollection } from 'astro:content';
import ArticleLayout from '../layouts/ArticleLayout.astro';
import { articleSlug, readingTimeMinutes } from '../lib/articles.ts';

export async function getStaticPaths() {
  const posts = await getCollection('articles', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: articleSlug(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const mdName = post.id.endsWith('.md') ? post.id : `${post.id}.md`;
const mdPath = path.join(process.cwd(), 'src/content/articles', mdName);
const raw = readFileSync(mdPath, 'utf8');
const bodyMd = raw.replace(/^---[\s\S]*?---\s*/, '');
const minutes = readingTimeMinutes(bodyMd);
---

<ArticleLayout
  title={post.data.title}
  date={post.data.date}
  description={post.data.description}
  readingTime={minutes}
>
  <article class="prose">
    <Content />
  </article>
</ArticleLayout>
