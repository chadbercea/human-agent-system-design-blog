---
import { readFileSync } from 'node:fs';
import path from 'node:path';
import { getCollection } from 'astro:content';
import SiteLayout from '../layouts/SiteLayout.astro';
import { articleSlug, getSortedArticles, readingTimeMinutes } from '../lib/articles.ts';

export async function getStaticPaths() {
  const posts = await getCollection('articles', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: articleSlug(post.id) },
    props: { post },
  }));
}

const { post } = Astro.props;
const articles = await getSortedArticles();
const { Content } = await post.render();

const mdName = post.id.endsWith('.md') ? post.id : `${post.id}.md`;
const mdPath = path.join(process.cwd(), 'src/content/articles', mdName);
const raw = readFileSync(mdPath, 'utf8');
const bodyMd = raw.replace(/^---[\s\S]*?---\s*/, '');
const minutes = readingTimeMinutes(bodyMd);

const dateLabel = post.data.date.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const desc = post.data.description ?? '';
---

<SiteLayout title={post.data.title} description={desc} articles={articles}>
  <header class="article-header">
    <h1>{post.data.title}</h1>
    <hr class="article-header__rule" />
    <p class="article-header__meta">
      {dateLabel}
      <span aria-hidden="true"> · </span>
      {minutes} min read
    </p>
  </header>
  {post.data.description && <p class="article-lede">{post.data.description}</p>}
  <article class="prose">
    <Content />
  </article>
  <footer class="article-footer">
    <a href="/">← All articles</a>
  </footer>
</SiteLayout>
