---
import HomepageLayout from '../layouts/HomepageLayout.astro';

const formId = import.meta.env.PUBLIC_FORMSPREE_FORM_ID ?? '';
const endpoint = formId ? `https://formspree.io/f/${formId}` : '';
---
<HomepageLayout title="Contact · HAS Design" activeNav="contact">
  <main class="prose-page">
    <article class="prose-inner">
      <p class="eyebrow">Get involved</p>
      <h1 class="prose-h1 h1-pending">Contact</h1>
      <div class="prose-body">
        <p>HAS-D is being built in public. That means the framework gets sharper through three kinds of input from the people working on the ground. Feedback: reactions to the premises, what's missing from v1.0, where the framing falls short. Testing: stories from real products, where the triad held, where it broke, what you learned applying it. Contributing: prior art HAS-D should be citing, phenomena worth naming, concepts that need sharpening. If you've got any of it, send it.</p>
      </div>

      <form
        class="contact-form"
        id="contact-form"
        action={endpoint}
        method="POST"
        novalidate
        data-endpoint={endpoint}
      >
        <label class="contact-field">
          <span class="contact-label">Name</span>
          <input type="text" id="cf-name" name="name" autocomplete="name" required />
        </label>
        <label class="contact-field">
          <span class="contact-label">Email</span>
          <input type="email" id="cf-email" name="email" autocomplete="email" required />
        </label>
        <label class="contact-field">
          <span class="contact-label">Message</span>
          <textarea id="cf-message" name="message" rows="6" minlength="20" required></textarea>
        </label>
        <p class="contact-status" id="cf-status" role="status" aria-live="polite"></p>
        <button type="submit" class="contact-send" id="cf-submit">Transmit</button>
      </form>
    </article>
  </main>

  <script is:inline>
    (function () {
      var form = document.getElementById('contact-form');
      if (!form) return;
      var endpoint = form.getAttribute('data-endpoint') || '';
      var status = document.getElementById('cf-status');
      var submit = document.getElementById('cf-submit');
      var nameEl = document.getElementById('cf-name');
      var emailEl = document.getElementById('cf-email');
      var messageEl = document.getElementById('cf-message');

      function setStatus(text, kind) {
        status.textContent = text;
        status.dataset.kind = kind || '';
      }

      function isEmail(v) {
        return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v);
      }

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        var name = (nameEl.value || '').trim();
        var email = (emailEl.value || '').trim();
        var message = (messageEl.value || '').trim();

        if (!name) return setStatus('Name is required.', 'error');
        if (!isEmail(email)) return setStatus('Enter a valid email.', 'error');
        if (message.length < 20) return setStatus('Message must be at least 20 characters.', 'error');
        if (!endpoint) return setStatus('Form is not configured. Set PUBLIC_FORMSPREE_FORM_ID.', 'error');

        submit.disabled = true;
        setStatus('Transmitting…', 'pending');

        fetch(endpoint, {
          method: 'POST',
          headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: name, email: email, message: message }),
        })
          .then(function (res) {
            if (res.ok) {
              window.location.href = '/thanks';
              return;
            }
            return res.json().then(function (data) {
              var msg = data && data.errors && data.errors[0] && data.errors[0].message;
              setStatus(msg || 'Something went wrong. Try again.', 'error');
              submit.disabled = false;
            });
          })
          .catch(function () {
            setStatus('Network error. Try again.', 'error');
            submit.disabled = false;
          });
      });
    })();
  </script>
</HomepageLayout>
