---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getSortedPosts, getPaginationForPosts } from '../../lib/blog';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const allPosts = await getSortedPosts();
  const { totalPages } = getPaginationForPosts(allPosts);
  return Array.from({ length: totalPages - 1 }, (_, i) => {
    const pageNum = i + 2; // page 2, 3, ...
    return {
      params: { page: String(pageNum) },
      props: {
        posts: getPaginationForPosts(allPosts).getPagePosts(pageNum),
        currentPage: pageNum,
        totalPages,
        prevUrl: pageNum === 2 ? '/' : `/page/${pageNum - 1}`,
        nextUrl: pageNum < totalPages ? `/page/${pageNum + 1}` : null,
      },
    };
  });
};

const { posts: pagePosts, currentPage, totalPages, prevUrl, nextUrl } = Astro.props;
---

<BaseLayout title="Blog" description="Human-agent system design blog." fullWidth>
  <article>
    <h1 class="listing-title mb-12">Blog</h1>
    <ol class="list-none p-0 m-0">
      {pagePosts.map((post) => (
        <PostCard post={post} animateIn />
      ))}
    </ol>
    <nav class="mt-12 pt-8 border-t border-border flex items-center justify-between gap-4 font-mono text-sm text-text-muted uppercase tracking-wider" aria-label="Pagination">
      {prevUrl ? (
        <a href={prevUrl} class="link">Previous</a>
      ) : (
        <span />
      )}
      <span>Page {currentPage} of {totalPages}</span>
      {nextUrl ? (
        <a href={nextUrl} class="link">Next</a>
      ) : (
        <span />
      )}
    </nav>
  </article>
</BaseLayout>
