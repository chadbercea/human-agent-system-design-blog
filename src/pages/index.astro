---
import SiteLayout from '../layouts/SiteLayout.astro';
import { articleSlug, getSortedArticles } from '../lib/articles.ts';

const articles = await getSortedArticles();
const title = 'HAS-DESIGN';

function formatDate(date: Date): string {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  return `${y}.${m}.${d}`;
}
---

<SiteLayout title={title} description="Human–agent system design writing." articles={articles}>
  <div class="freq-log">
    <div class="freq-log__header">
      <div class="sys">FREQ ░░ 140.85 // HAS-DESIGN</div>
      <p class="freq-log__tagline">Human · Agent · System</p>
    </div>
    <hr class="tx-rule" />
    <div class="sys freq-log__label">TRANSMISSION LOG</div>
    <hr class="tx-rule" />
    <ul class="freq-log__list">
      {
        articles.map((a) => (
          <li class="freq-log__item">
            <a href={`/${articleSlug(a.id)}`} class="freq-log__title">
              {a.data.title}
            </a>
            <time class="freq-log__date sys" datetime={a.data.date.toISOString()}>
              {formatDate(a.data.date)}
            </time>
          </li>
        ))
      }
    </ul>
  </div>
</SiteLayout>

<style>
  .freq-log {
    max-width: var(--measure-wide);
  }

  .freq-log__header {
    margin-block-end: var(--space-4);
  }

  .freq-log__tagline {
    font-family: var(--font-prose);
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    margin: var(--space-2) 0 0;
  }

  .freq-log__label {
    margin-block: var(--space-3);
  }

  .freq-log__list {
    list-style: none;
    padding: 0;
    margin: var(--space-6) 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .freq-log__item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
  }

  .freq-log__title {
    font-family: var(--font-prose);
    font-size: var(--text-base);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .freq-log__title:hover {
    color: var(--color-accent);
  }

  .freq-log__date {
    flex-shrink: 0;
  }
</style>
