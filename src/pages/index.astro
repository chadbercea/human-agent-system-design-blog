---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getSortedPosts, getPaginationForPosts } from '../lib/blog';

const allPosts = await getSortedPosts();
const { getPagePosts, totalPages } = getPaginationForPosts(allPosts);
const posts = getPagePosts(1);
---

<BaseLayout title="Blog" description="Human-agent system design blog.">
  <article>
    <h1 class="text-4xl font-bold text-text mb-8">Blog</h1>
    <ol class="list-none p-0 m-0 flex flex-col gap-4">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </ol>
    <nav class="mt-8 pt-6 border-t border-border flex items-center justify-between gap-4" aria-label="Pagination">
      <span />
      <span class="text-sm text-text-muted">
        Page 1 of {totalPages}
      </span>
      {totalPages > 1 ? (
        <a href="/page/2" class="text-accent underline underline-offset-2">
          Next
        </a>
      ) : (
        <span />
      )}
    </nav>
  </article>
</BaseLayout>
