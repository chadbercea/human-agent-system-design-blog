---
import { getCollection } from 'astro:content';
import HomepageLayout from '../layouts/HomepageLayout.astro';

const articles = (await getCollection('articles'))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(d: Date): string {
  const y = d.getUTCFullYear();
  const m = String(d.getUTCMonth() + 1).padStart(2, '0');
  const day = String(d.getUTCDate()).padStart(2, '0');
  return `${y}.${m}.${day}`;
}

const entryCount = String(articles.length).padStart(3, '0');
const lastUpdated = articles.length > 0 ? formatDate(articles[0].data.date) : '—';

const rendered = await Promise.all(
  articles.map(async (a) => {
    const { Content } = await a.render();
    return { article: a, Content };
  })
);

function readMinutes(body: string): number {
  const words = body.trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 220));
}

const articleMeta = articles.map((a) => {
  const minutes = readMinutes(a.body);
  const base = [...(a.data.tags ?? []), formatDate(a.data.date)].join(' · ');
  return {
    slug: a.slug,
    title: a.data.title,
    lede: a.data.description ?? '',
    eyebrow: `${base} · ${minutes} min read`,
  };
});

const featured = articles[0];
const siteDescription = featured?.data.description
  ?? 'A blog about Human-Agent-System Design. Humans, agents, and systems shipping products together.';
---
<HomepageLayout title="HAS Design" description={siteDescription} activeNav="articles">
  <div class="stage" id="stage">
    <div class="col col-hero">
      <div class="hero-inner">
        <div class="protocol-chip">PROTOCOL 001 &middot; PHASE ALPHA</div>

        <div class="hero-stack">
          <div class="hero-logo">
            <div class="logo-stage">
              <div class="bar full" style="top:30px;left:42px;transform:rotate(45deg)"></div>
              <div class="bar full" style="top:30px;left:115px;transform:rotate(45deg)"></div>
              <div class="bar half" style="top:81px;left:165px;transform:rotate(-45deg)"></div>
              <div class="bar half" style="top:32.6px;left:220.2px;transform:rotate(90deg)"></div>
              <div class="bar half" style="top:53.8px;left:211.4px;transform:rotate(-45deg)"></div>
              <div class="bar half" style="top:66.2px;left:253.8px;transform:rotate(-45deg)"></div>
              <div class="bar half" style="top:87.4px;left:245px;transform:rotate(90deg)"></div>
            </div>
          </div>

          <div class="hero-sub">
            <svg viewBox="0 0 275.44 15" xmlns="http://www.w3.org/2000/svg" aria-label="BUILDING IN PUBLIC · HUMAN × AGENT">
              <text x="0" y="12" font-family="'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace" font-size="13" font-weight="500" fill="currentColor" textLength="275.44" lengthAdjust="spacing">BUILDING IN PUBLIC &middot; HUMAN &times; AGENT</text>
            </svg>
          </div>

          <div class="hero-meta">
            <span>WRITING</span>
            <span class="slash">/</span>
            <span>SHIPPING</span>
            <span class="slash">/</span>
            <span>THINKING OUT LOUD</span>
          </div>
        </div>

        <div class="hud-corner tl">
          <strong>OBS // SITE</strong>
          42.56&deg;N &middot; 114.46&deg;W<br />
          <span class="dim">TWIN FALLS / IDAHO</span><br />
          T+LIVE
        </div>
        <div class="hud-corner tr">
          <strong>INDEX // LIVE</strong>
          ENTRIES {entryCount}<br />
          UPD {lastUpdated}<br />
          <span class="dim">CH 01 / DISPATCH</span>
        </div>
        <div class="hud-corner bl">
          <strong>STATUS // LINK</strong>
          AGENT-01 &nbsp; ONLINE<br />
          OPERATOR &nbsp; LINKED<br />
          <span class="dim">HANDSHAKE &middot; OK</span>
        </div>
        <div class="hud-corner br">
          <strong>BUILD // META</strong>
          REV 01.00<br />
          HASH 9F2A-8C1D<br />
          <span class="dim">GAMMA &middot; sRGB</span>
        </div>
      </div>
      <button class="back-btn" id="back-btn" aria-label="Back to articles">
        <span class="back-content">
          <span class="back-arrow">←</span>
          <span>Back</span>
        </span>
      </button>
    </div>
    <div class="col col-list">
      <span class="list-label">Published Articles</span>
      <ul class="article-list" id="article-list">
        {articles.map((a, i) => (
          <li class="article-item" data-index={i} data-slug={a.slug}>
            <div class="ai-meta">
              <span>{String(i + 1).padStart(2, '0')}</span>
              <span class="ai-date">{formatDate(a.data.date)}</span>
            </div>
            <div class="ai-title">{a.data.title}</div>
          </li>
        ))}
      </ul>
    </div>
    <div class="col col-article">
      <button class="mobile-back" id="mobile-back" aria-label="Back to articles">
        <span>←</span>
        <span>All Articles</span>
      </button>
      <article class="article-inner">
        <div class="art-eyebrow" id="art-eyebrow"></div>
        <h1 class="art-h1" id="art-h1"></h1>
        <p class="art-lede" id="art-lede"></p>
        <div class="art-body" id="art-body"></div>
        <div class="art-end" aria-hidden="true">·&nbsp;·&nbsp;·</div>
      </article>
    </div>
  </div>

  <Fragment slot="after-shell">
    <div hidden aria-hidden="true">
      {rendered.map(({ article, Content }) => (
        <div id={`body-${article.slug}`}><Content /></div>
      ))}
    </div>

    <script type="application/json" id="article-meta" is:inline set:html={JSON.stringify(articleMeta)} />

    <script is:inline>
      (function () {
        var meta = [];
        try {
          meta = JSON.parse(document.getElementById('article-meta').textContent || '[]');
        } catch (e) { meta = []; }

        var stage = document.getElementById('stage');
        var items = document.querySelectorAll('.article-item');
        var backBtn = document.getElementById('back-btn');
        var mobileBack = document.getElementById('mobile-back');
        var colArticle = document.querySelector('.col-article');
        var eyebrowEl = document.getElementById('art-eyebrow');
        var h1El = document.getElementById('art-h1');
        var ledeEl = document.getElementById('art-lede');
        var bodyEl = document.getElementById('art-body');
        var savedScrollY = 0;

        function openArticle(idx) {
          var data = meta[idx];
          if (!data) return;
          var wasOpen = stage.classList.contains('open');
          if (!wasOpen) {
            savedScrollY = window.scrollY || window.pageYOffset || 0;
          }
          eyebrowEl.textContent = data.eyebrow;
          h1El.textContent = data.title;
          ledeEl.textContent = data.lede;
          var src = document.getElementById('body-' + data.slug);
          bodyEl.innerHTML = src ? src.innerHTML : '';
          items.forEach(function (el) { el.classList.remove('active'); });
          var activeEl = items[idx];
          if (activeEl) activeEl.classList.add('active');
          stage.classList.add('open');
          window.scrollTo(0, 0);
          if (colArticle) colArticle.scrollTop = 0;
        }

        function closeArticle() {
          stage.classList.remove('open');
          items.forEach(function (el) { el.classList.remove('active'); });
          window.scrollTo(0, savedScrollY);
        }

        items.forEach(function (el) {
          el.addEventListener('click', function () {
            var idx = parseInt(el.getAttribute('data-index'), 10);
            openArticle(idx);
          });
        });

        if (backBtn) backBtn.addEventListener('click', closeArticle);
        if (mobileBack) mobileBack.addEventListener('click', closeArticle);
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') closeArticle();
        });
      })();
    </script>
  </Fragment>
</HomepageLayout>
