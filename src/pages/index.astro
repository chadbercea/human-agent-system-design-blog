---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(d: Date): string {
  return d.toISOString().slice(0, 10).replace(/-/g, '.');
}
---

<SiteLayout title="HAS-DESIGN" description="Human–agent system design writing.">
  <!-- Hit zone — covers left margin when reading -->
  <div class="hit-zone" id="hit-zone"></div>

  <!-- LIST LAYER -->
  <div class="layer z-front" id="layer-list">
    <ul class="alist">
      {articles.map(article => (
        <li
          class="ali"
          data-slug={article.id.replace(/\.md$/i, '')}
          data-title={article.data.title}
          data-date={formatDate(article.data.date)}
          data-description={article.data.description || ''}
        >
          <span class="alt">{article.data.title}</span>
          <span class="ald">{formatDate(article.data.date)}</span>
        </li>
      ))}
    </ul>
  </div>

  <!-- ARTICLE LAYER (empty shell, filled by JS) -->
  <div class="layer z-gone" id="layer-article">
    <h1 class="art-title" id="art-title"></h1>
    <div class="art-meta">
      <span id="art-date"></span>
      <span id="art-read"></span>
    </div>
    <p class="art-lede" id="art-lede"></p>
    <div class="art-body" id="art-body"></div>
  </div>
</SiteLayout>

<style>
  /* ── Layer system ── */
  .layer {
    position: absolute;
    inset: 0;
    overflow-y: auto;
    transition: transform 0.5s ease, filter 0.5s ease, opacity 0.5s ease;
    will-change: transform, filter, opacity;
    padding: var(--content-padding-y) var(--content-padding-x);
  }

  @media (prefers-reduced-motion: reduce) {
    .layer {
      transition: none;
    }
  }

  .z-front {
    transform: scale(1) translateZ(0);
    filter: blur(0);
    opacity: 1;
    pointer-events: auto;
    z-index: 2;
  }

  .z-back {
    transform: scale(0.92) translateZ(0);
    filter: blur(4px);
    opacity: 0.5;
    pointer-events: none;
    z-index: 1;
  }

  .z-gone {
    transform: scale(0.85) translateZ(0);
    filter: blur(8px);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
  }

  .z-ef {
    transform: scale(1.1) translateZ(0);
    filter: blur(6px);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
  }

  .z-crisp {
    transform: translateX(-20vw) scale(0.72);
    transform-origin: left center;
    filter: blur(0);
    opacity: 1;
    pointer-events: none;
    z-index: 20;
  }

  .z-dim {
    transform: none;
    filter: blur(14px);
    opacity: 0.25;
    pointer-events: none;
    z-index: 10;
  }

  /* ── Hit zone ── */
  .hit-zone {
    display: none;
    position: absolute;
    top: 0;
    left: 0;
    width: var(--space-16);
    height: 100%;
    z-index: 10;
    cursor: pointer;
  }

  .hit-zone.on {
    display: block;
  }

  /* Hit zone is mouse-only; disable on touch devices */
  @media (hover: none) {
    .hit-zone,
    .hit-zone.on {
      display: none;
    }
  }

  /* ── Article list ── */
  .alist {
    max-width: var(--measure-prose);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .ali {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
    cursor: pointer;
  }

  .alt {
    font-family: var(--font-prose);
    font-size: var(--text-base);
    color: var(--color-text-primary);
  }

  .ali:hover .alt,
  .ali.hi .alt {
    color: var(--color-accent);
  }

  .ali.hi,
  .ali:hover {
    transform: translateX(6px);
  }

  @media (prefers-reduced-motion: reduce) {
    .ali.hi,
    .ali:hover {
      transform: none;
    }
  }

  .ald {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    flex-shrink: 0;
  }

  /* ── Mobile article list ── */
  @media (max-width: 768px) {
    .ali {
      flex-direction: column;
      gap: var(--space-1);
    }
  }

  /* ── Article layer ── */
  .art-title {
    font-family: var(--font-prose);
    font-size: var(--text-3xl);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-4);
    max-width: var(--measure-prose);
  }

  .art-meta {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    display: flex;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .art-lede {
    font-family: var(--font-prose);
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    margin: 0 0 var(--space-8);
    max-width: var(--measure-prose);
  }

  .art-body {
    max-width: var(--measure-prose);
  }
</style>

<script>
  import '../scripts/nav.js';
  import '../scripts/articles.js';
</script>
