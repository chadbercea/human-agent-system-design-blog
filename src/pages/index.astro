---
import SiteLayout from '../layouts/SiteLayout.astro';
import AboutContent from '../components/AboutContent.astro';
import ContactContent from '../components/ContactContent.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(d: Date): string {
  return d.toISOString().slice(0, 10).replace(/-/g, '.');
}
---

<SiteLayout title="HAS-DESIGN" description="Human–agent system design writing.">
  <!-- Hit zone — covers left margin when reading -->
  <div class="hit-zone" id="hit-zone"></div>

  <!-- LIST LAYER -->
  <div class="layer z-front" id="layer-list">
    <ul class="alist">
      {articles.map(article => (
        <li
          class="ali"
          data-slug={article.id.replace(/\.md$/i, '')}
          data-title={article.data.title}
          data-date={formatDate(article.data.date)}
          data-description={article.data.description || ''}
        >
          <span class="alt">{article.data.title}</span>
          <span class="ald">{formatDate(article.data.date)}</span>
        </li>
      ))}
    </ul>
  </div>

  <!-- ABOUT LAYER -->
  <div class="layer layer-meta z-gone" id="layer-about">
    <AboutContent />
  </div>

  <!-- CONTACT LAYER -->
  <div class="layer layer-meta z-gone" id="layer-contact">
    <ContactContent />
  </div>

  <!-- ARTICLE LAYER (empty shell, filled by JS) -->
  <div class="layer z-gone" id="layer-article">
    <header class="art-header">
      <h1 class="art-title" id="art-title"></h1>
      <div class="art-date" id="art-date"></div>
      <p class="art-lede" id="art-lede"></p>
    </header>
    <div class="art-body prose" id="art-body"></div>
    <footer class="art-footer">
      <a href="/" id="art-back" class="art-back">&larr; Back</a>
    </footer>
  </div>
</SiteLayout>

<style>
  /* ── Layer system ── */
  .layer {
    position: absolute;
    top: 0;
    bottom: 0;
    min-width: 0;
    overflow-x: hidden;
    overflow-y: auto;
    overscroll-behavior: contain;
    transition: transform var(--dur) var(--ease), filter var(--dur) var(--ease), opacity calc(var(--dur) * 0.75) var(--ease);
    will-change: transform, filter, opacity;
    padding-top: clamp(2rem, 4vh, 4rem);
    padding-bottom: clamp(2rem, 4vh, 4rem);
  }

  @media (prefers-reduced-motion: reduce) {
    .layer {
      transition: none;
    }
  }

  .z-front {
    transform: none;
    filter: blur(0);
    opacity: 1;
    pointer-events: all;
    z-index: 10;
  }

  .z-back {
    transform: translateX(-12vw) scale(0.8);
    transform-origin: left center;
    filter: blur(6px);
    opacity: 0.28;
    pointer-events: none;
    z-index: 20;
  }

  .z-gone {
    transform: perspective(1200px) translateZ(-120px) scale(0.92);
    filter: blur(14px);
    opacity: 0;
    pointer-events: none;
    z-index: 1;
  }

  .z-ef {
    transform: perspective(1200px) translateZ(72px) scale(1.04);
    filter: blur(12px);
    opacity: 0;
    pointer-events: none;
    z-index: 10;
  }

  .z-eb {
    transform: perspective(1200px) translateZ(-180px) scale(0.88);
    filter: blur(12px);
    opacity: 0;
    pointer-events: none;
    z-index: 10;
  }

  .z-crisp {
    transform: translateX(-12vw) scale(0.8);
    transform-origin: left center;
    filter: blur(0);
    opacity: 1;
    pointer-events: none;
    z-index: 20;
  }

  .z-dim {
    transform: none;
    filter: blur(14px);
    opacity: 0.25;
    pointer-events: none;
    z-index: 10;
  }

  /*
   * Article layer at rest: starts FORWARD of the focal plane (positive Z)
   * so the z-gone → z-front transition pulls it back into focus.
   * Generic .z-gone uses negative Z (behind camera) — wrong direction for articles.
   */
  #layer-article.z-gone {
    transform: perspective(1200px) translateZ(60px) scale(1.03);
    filter: blur(10px);
    opacity: 0;
    pointer-events: none;
    z-index: 1;
  }

  /* ── Layer content area — full-width so scrollbar sits at browser edge ── */
  .layer {
    left: 0;
    right: 0;
    padding-left: 20vw;
    padding-right: clamp(1.5rem, 3vw, 3rem);
  }

  /* ── Hit zone ── */
  .hit-zone {
    display: none;
    position: absolute;
    top: 0;
    left: 0;
    width: 20vw;
    height: 100%;
    z-index: 30;
    cursor: pointer;
  }

  .hit-zone.on {
    display: block;
  }

  /* Hit zone is mouse-only; disable on touch devices */
  @media (hover: none) {
    .hit-zone,
    .hit-zone.on {
      display: none;
    }
  }

  /* ── Meta layer content (About / Contact) ── */
  .layer-meta {
    max-width: var(--measure-prose);
    margin: 0 auto;
  }

  .pg-title {
    font-family: var(--font-ui);
    font-size: var(--text-title);
    font-weight: 800;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0;
  }

  .pg-sub {
    max-width: clamp(45ch, 60vw, 75ch);
    margin: var(--space-4) 0 0;
    color: var(--color-text-secondary);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
  }

  .field {
    display: flex;
    gap: var(--space-4);
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .field:first-of-type {
    margin-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .fk {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    min-width: 10ch;
    flex-shrink: 0;
  }

  .fv {
    font-family: var(--font-prose);
    font-size: var(--text-sm);
    color: var(--color-text-primary);
  }

  /* ── Article list ── */
  .alist {
    list-style: none;
    display: flex;
    flex-direction: column;
    width: 100%;
    min-width: 0;
  }

  .ali {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    width: 100%;
    min-width: 0;
    padding: 0.5rem 0;
    cursor: pointer;
    transition: transform 0.18s var(--ease);
  }

  .alt {
    flex: 1;
    min-width: 0;
    font-family: var(--font-ui);
    font-size: clamp(1.8rem, 3.5vw, 3.2rem);
    font-weight: 800;
    color: var(--color-text-secondary);
    line-height: 1.15;
    letter-spacing: -0.02em;
    overflow-wrap: anywhere;
    transition: color 0.15s;
  }

  .ali:hover .alt,
  .ali.hi .alt {
    color: var(--color-text-primary);
  }

  .ali.hi,
  .ali:hover {
    transform: translateX(6px);
  }

  @media (prefers-reduced-motion: reduce) {
    .ali.hi,
    .ali:hover {
      transform: none;
    }
  }

  .ald {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
    text-align: right;
    white-space: nowrap;
    transition: color 0.15s;
  }

  .ali:hover .ald,
  .ali.hi .ald {
    color: var(--color-text-secondary);
  }

  /* ── Mobile article list ── */
  @media (max-width: 768px) {
    .layer {
      padding-left: clamp(1.5rem, 3vw, 3rem);
    }

    .ald {
      text-align: right;
    }
  }

  /* ── Article layer ── */
  .art-header {
    margin-bottom: clamp(2rem, 4vw, 4rem);
  }

  .art-title {
    font-family: var(--font-ui);
    font-size: var(--text-title);
    font-weight: 800;
    line-height: var(--leading-tight);
    letter-spacing: var(--tracking-tight);
    color: var(--color-text-primary);
    margin: 0;
  }

  .art-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-top: var(--space-3);
  }

  .art-lede {
    max-width: 54ch;
    margin: var(--space-4) 0 var(--space-8);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-family: var(--font-prose);
    font-size: clamp(0.9rem, 1.35vw, 1.05rem);
    font-style: italic;
    line-height: 1.68;
  }

  .art-lede:empty {
    display: none;
  }

  .art-body {
    max-width: clamp(45ch, 60vw, 75ch);
  }

  /* ── Article entrance: opacity only (no translate — avoids compositor/hover pixel shift) ── */
  @keyframes prose-fade-in {
    from {
      opacity: 0;
    }

    to {
      opacity: 1;
    }
  }

  #layer-article .art-header.art-header--enter .art-title {
    animation: prose-fade-in 0.38s var(--ease) backwards;
  }

  #layer-article .art-header.art-header--enter .art-date {
    animation: prose-fade-in 0.38s var(--ease) backwards;
    animation-delay: 0.05s;
  }

  #layer-article .art-header.art-header--enter .art-lede:not(:empty) {
    animation: prose-fade-in 0.38s var(--ease) backwards;
    animation-delay: 0.1s;
  }

  #layer-article .art-body.prose--enter > * {
    animation: prose-fade-in 0.34s var(--ease) backwards;
  }

  #layer-article .art-body.prose--enter > *:nth-child(1) {
    animation-delay: 0.03s;
  }
  #layer-article .art-body.prose--enter > *:nth-child(2) {
    animation-delay: 0.06s;
  }
  #layer-article .art-body.prose--enter > *:nth-child(3) {
    animation-delay: 0.09s;
  }
  #layer-article .art-body.prose--enter > *:nth-child(4) {
    animation-delay: 0.12s;
  }
  #layer-article .art-body.prose--enter > *:nth-child(5) {
    animation-delay: 0.15s;
  }
  #layer-article .art-body.prose--enter > *:nth-child(6) {
    animation-delay: 0.18s;
  }
  #layer-article .art-body.prose--enter > *:nth-child(7) {
    animation-delay: 0.21s;
  }
  #layer-article .art-body.prose--enter > *:nth-child(8) {
    animation-delay: 0.24s;
  }
  #layer-article .art-body.prose--enter > *:nth-child(9) {
    animation-delay: 0.27s;
  }
  #layer-article .art-body.prose--enter > *:nth-child(10) {
    animation-delay: 0.3s;
  }
  #layer-article .art-body.prose--enter > *:nth-child(n + 11) {
    animation-delay: 0.33s;
  }

  #layer-article .art-footer.art-footer--enter {
    animation: prose-fade-in 0.38s var(--ease) backwards;
    animation-delay: 0.28s;
  }

  /* Link hover: color only — no layout-affecting change inside faded blocks */
  #layer-article .art-body.prose a {
    transition:
      color 0.16s ease,
      text-decoration-color 0.16s ease;
  }

  .art-load-err {
    font-family: var(--font-prose);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: var(--space-4) 0;
  }

  @media (prefers-reduced-motion: reduce) {
    #layer-article .art-header.art-header--enter .art-title,
    #layer-article .art-header.art-header--enter .art-date,
    #layer-article .art-header.art-header--enter .art-lede,
    #layer-article .art-body.prose--enter > *,
    #layer-article .art-footer.art-footer--enter {
      animation: none;
      opacity: 1;
    }
  }

  .art-footer {
    margin-top: clamp(3rem, 6vw, 6rem);
  }

  .art-footer a {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .art-footer a:hover {
    color: var(--color-accent);
  }
</style>

<script>
  import '../scripts/nav.js';
  import '../scripts/articles.js';
</script>
