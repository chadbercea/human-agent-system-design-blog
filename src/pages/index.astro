---
import SiteLayout from '../layouts/SiteLayout.astro';
import { articleSlug, getSortedArticles } from '../lib/articles.ts';

const articles = await getSortedArticles();
const title = 'HAS-DESIGN';

function formatDate(date: Date): string {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, '0');
  const d = String(date.getDate()).padStart(2, '0');
  return `${y}.${m}.${d}`;
}
---

<SiteLayout title={title} description="Human–agent system design writing.">
  <h1 class="page-title">Human · Agent · System</h1>
  <ul class="article-list">
    {
      articles.map((a) => (
        <li class="article-list__item">
          <a href={`/${articleSlug(a.id)}`} class="article-list__title">
            {a.data.title}
          </a>
          <time class="article-list__date" datetime={a.data.date.toISOString()}>
            {formatDate(a.data.date)}
          </time>
        </li>
      ))
    }
  </ul>
</SiteLayout>

<style>
  .page-title {
    font-family: var(--font-prose);
    font-size: var(--text-lg);
    font-weight: 400;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-8);
  }

  .article-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .article-list__item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-4);
  }

  .article-list__title {
    font-family: var(--font-prose);
    font-size: var(--text-base);
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .article-list__title:hover {
    color: var(--color-accent);
  }

  .article-list__date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    flex-shrink: 0;
  }
</style>
