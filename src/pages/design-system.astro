---
import DesignSystemLayout from '../layouts/DesignSystemLayout.astro';
---
<DesignSystemLayout title="HAS Design System">
  <div class="topbar">
    <div class="mark">
      <span class="dot"></span>
      <span class="name">HAS / STYLE</span>
    </div>
    <span></span>
    <div class="kv"><span class="k">REV</span><span class="v">01.00</span></div>
    <div class="kv"><span class="k">BUILD</span><span class="v">2026.04.23</span></div>
    <div class="kv"><span class="k">HASH</span><span class="v">9F2A-8C1D</span></div>
    <div class="kv"><span class="k">CH</span><span class="v">01 / OPS</span></div>
  </div>

  <section class="hero">
    <div class="hud-corner tl">
      <strong>OBS // SITE</strong>
      42.56°N · 114.46°W<br />
      <span class="dim">TWIN FALLS / IDAHO</span><br />
      T+00:32:18
    </div>
    <div class="hud-corner tr">
      <strong>SPEC // GEOMETRY</strong>
      DIM 420 × 180<br />
      7 BARS / 2 UNITS<br />
      <span class="dim">ISSUE ILI-699</span>
    </div>
    <div class="hud-corner bl">
      <strong>STATUS // LINK</strong>
      AGENT-01 &nbsp; ONLINE<br />
      OPERATOR &nbsp; LINKED<br />
      <span class="dim">HANDSHAKE · OK</span>
    </div>
    <div class="hud-corner br">
      <strong>BUILD // META</strong>
      REV 01.00<br />
      HASH 9F2A-8C1D<br />
      <span class="dim">GAMMA · sRGB</span>
    </div>

    <div class="hero-logo">
      <div class="logo-stage">
        <div class="bar full" style="top:30px;left:42px;transform:rotate(45deg)"></div>
        <div class="bar full" style="top:30px;left:115px;transform:rotate(45deg)"></div>
        <div class="bar half" style="top:81px;left:165px;transform:rotate(-45deg)"></div>
        <div class="bar half" style="top:32.6px;left:220.2px;transform:rotate(90deg)"></div>
        <div class="bar half" style="top:53.8px;left:211.4px;transform:rotate(-45deg)"></div>
        <div class="bar half" style="top:66.2px;left:253.8px;transform:rotate(-45deg)"></div>
        <div class="bar half" style="top:87.4px;left:245px;transform:rotate(90deg)"></div>
      </div>
    </div>

    <div class="hero-sub">
      <svg viewBox="0 0 275.44 15" xmlns="http://www.w3.org/2000/svg" aria-label="HUMAN AGENT SYSTEM DESIGN">
        <text x="0" y="12" font-family="'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace" font-size="13" font-weight="500" fill="currentColor" textLength="275.44" lengthAdjust="spacing">HUMAN AGENT SYSTEM DESIGN</text>
      </svg>
    </div>

    <div class="hero-meta">
      <span>GEOMETRIC WORDMARK</span>
      <span class="slash">/</span>
      <span>TWO HEXAGONAL PRIMITIVES</span>
      <span class="slash">/</span>
      <span>SEVEN POSITIONED BARS</span>
    </div>
  </section>
</DesignSystemLayout>
