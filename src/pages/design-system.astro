---
import DesignSystemLayout from '../layouts/DesignSystemLayout.astro';
import CategoryGlyph from '../components/CategoryGlyph.astro';
import CategoryBadge from '../components/CategoryBadge.astro';
import FrameworkLocator from '../components/FrameworkLocator.astro';
import ConceptLink from '../components/ConceptLink.astro';
import { getAllCategories, getCategoryBySlug } from '../lib/has-framework';

const categories = await getAllCategories();
const categoriesWithMembers = await Promise.all(
  categories.map(async (c) => (await getCategoryBySlug(c.data.slug))!),
);
---
<DesignSystemLayout title="HAS Design System">
  <section class="hero">
    <div class="hud-corner tl">
      <strong>OBS // SITE</strong>
      42.56°N · 114.46°W<br />
      <span class="dim">TWIN FALLS / IDAHO</span><br />
      T+00:32:18
    </div>
    <div class="hud-corner tr">
      <strong>SPEC // GEOMETRY</strong>
      DIM 420 × 180<br />
      7 BARS / 2 UNITS<br />
      <span class="dim">ISSUE ILI-699</span>
    </div>
    <div class="hud-corner bl">
      <strong>STATUS // LINK</strong>
      AGENT-01 &nbsp; ONLINE<br />
      OPERATOR &nbsp; LINKED<br />
      <span class="dim">HANDSHAKE · OK</span>
    </div>
    <div class="hud-corner br">
      <strong>BUILD // META</strong>
      REV 01.00<br />
      HASH 9F2A-8C1D<br />
      <span class="dim">GAMMA · sRGB</span>
    </div>

    <div class="hero-logo">
      <div class="logo-stage">
        <div class="bar full" style="top:30px;left:42px;transform:rotate(45deg)"></div>
        <div class="bar full" style="top:30px;left:115px;transform:rotate(45deg)"></div>
        <div class="bar half" style="top:81px;left:165px;transform:rotate(-45deg)"></div>
        <div class="bar half" style="top:32.6px;left:220.2px;transform:rotate(90deg)"></div>
        <div class="bar half" style="top:53.8px;left:211.4px;transform:rotate(-45deg)"></div>
        <div class="bar half" style="top:66.2px;left:253.8px;transform:rotate(-45deg)"></div>
        <div class="bar half" style="top:87.4px;left:245px;transform:rotate(90deg)"></div>
      </div>
    </div>

    <div class="hero-sub">
      <svg viewBox="0 0 275.44 15" xmlns="http://www.w3.org/2000/svg" aria-label="HUMAN AGENT SYSTEM DESIGN">
        <text x="0" y="12" font-family="'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace" font-size="13" font-weight="500" fill="currentColor" textLength="275.44" lengthAdjust="spacing">HUMAN AGENT SYSTEM DESIGN</text>
      </svg>
    </div>

    <div class="hero-meta">
      <span>GEOMETRIC WORDMARK</span>
      <span class="slash">/</span>
      <span>TWO HEXAGONAL PRIMITIVES</span>
      <span class="slash">/</span>
      <span>SEVEN POSITIONED BARS</span>
    </div>
  </section>

  <section class="panel reveal">
    <div class="panel-rail"><span><strong>01 &nbsp; PRINCIPLES</strong></span></div>
    <div class="panel-head">
      <span class="id">// 01</span>
      <span class="title">PRINCIPLES · HUMAN &times; AGENT</span>
      <span class="meta">3 ROLES / 1 CONTRACT</span>
    </div>

    <p class="principles-quote">
      <span class="q-mark">&mdash;</span>A system is not a tool. It is a <em>collaboration</em>. Intent is held by the human; execution is carried by the agent; the work lives in the <em>handoff</em> between them.
    </p>

    <div class="triad">
      <div class="triad-cell">
        <span class="cell-id">// ROLE 01</span>
        <span class="cell-name">Human</span>
        <p class="cell-def">Holds the intent. Sets the direction. Decides what is worth doing and when the answer is good enough.</p>
        <dl>
          <dt>VERB</dt><dd>DECIDE</dd>
          <dt>ASKS</dt><dd>WHY</dd>
          <dt>BRINGS</dt><dd>JUDGMENT</dd>
          <dt>OUTPUT</dt><dd>INTENT</dd>
        </dl>
      </div>
      <div class="triad-cell">
        <span class="cell-id">// ROLE 02</span>
        <span class="cell-name">Agent</span>
        <p class="cell-def">Carries the execution. Proposes, reaches, iterates. Works at machine speed under human direction.</p>
        <dl>
          <dt>VERB</dt><dd>EXECUTE</dd>
          <dt>ASKS</dt><dd>HOW</dd>
          <dt>BRINGS</dt><dd>REACH</dd>
          <dt>OUTPUT</dt><dd>ACTION</dd>
        </dl>
      </div>
      <div class="triad-cell">
        <span class="cell-id">// ROLE 03</span>
        <span class="cell-name">System</span>
        <p class="cell-def">Governs the handoff. Makes trust legible, decisions reversible, and the collaboration auditable end to end.</p>
        <dl>
          <dt>VERB</dt><dd>GOVERN</dd>
          <dt>ASKS</dt><dd>HOW MUCH</dd>
          <dt>BRINGS</dt><dd>CONTRACT</dd>
          <dt>OUTPUT</dt><dd>TRUST</dd>
        </dl>
      </div>
    </div>

    <div class="footnotes">
      <div class="fn"><span class="n">FN.01</span>The human-in-the-loop is not a bottleneck &mdash; it is the source of direction. Remove it and you have speed without a course.</div>
      <div class="fn"><span class="n">FN.02</span>Trust is a protocol layer, not a feeling. It is versioned, audited, reversible. Every agent move leaves a trace.</div>
      <div class="fn"><span class="n">FN.03</span>Velocity = Clarity &times; Capability &times; Confidence. Lower any term and the product collapses toward zero.</div>
    </div>
  </section>

  <section class="panel reveal">
    <div class="panel-rail"><span><strong>02 &nbsp; TYPOGRAPHY</strong></span></div>
    <div class="panel-head">
      <span class="id">// 02</span>
      <span class="title">TYPOGRAPHY &middot; TWO VOICES</span>
      <span class="meta">SANS &middot; MONO</span>
    </div>

    <div class="specimen">
      <div class="spec-meta">
        <div><span class="k">Family</span><span class="v">Lato</span></div>
        <div><span class="k">Class</span><span class="v">Humanist Sans</span></div>
        <div><span class="k">Voice</span><span class="v">The Human</span></div>
        <div><span class="k">Role</span><span class="v">Display &amp; Body</span></div>
      </div>
      <div class="spec-display">
        <span class="huge">Aa</span>
        <span class="codepoint">U+0041 / U+0061 &mdash; WARM &middot; OPEN &middot; DELIBERATE</span>
        <div class="glyph-grid glyph-grid--sans">
          <span class="glyph">A</span><span class="glyph">B</span><span class="glyph">C</span><span class="glyph">D</span><span class="glyph">E</span><span class="glyph">F</span><span class="glyph">G</span><span class="glyph">H</span><span class="glyph">I</span>
          <span class="glyph">J</span><span class="glyph">K</span><span class="glyph">L</span><span class="glyph">M</span><span class="glyph">N</span><span class="glyph">O</span><span class="glyph">P</span><span class="glyph">Q</span><span class="glyph">R</span>
          <span class="glyph">S</span><span class="glyph">T</span><span class="glyph">U</span><span class="glyph">V</span><span class="glyph">W</span><span class="glyph">X</span><span class="glyph">Y</span><span class="glyph">Z</span><span class="glyph">0</span>
          <span class="glyph">1</span><span class="glyph">2</span><span class="glyph">3</span><span class="glyph">4</span><span class="glyph">5</span><span class="glyph">6</span><span class="glyph">7</span><span class="glyph">8</span><span class="glyph">9</span>
        </div>
      </div>
      <p class="spec-pangram">The human voice carries intent. It breathes, it pauses, it chooses its words &mdash; warmth is the signature of a mind that decides what is worth saying.</p>
      <div class="spec-weights">
        <div class="weight"><span class="big sans-100">Aa</span><span class="label">Hairline &mdash; 100</span></div>
        <div class="weight"><span class="big sans-300">Aa</span><span class="label">Light &mdash; 300</span></div>
        <div class="weight"><span class="big sans-700">Aa</span><span class="label">Bold &mdash; 700</span></div>
        <div class="weight"><span class="big sans-900">Aa</span><span class="label">Black &mdash; 900</span></div>
      </div>
    </div>

    <div class="specimen">
      <div class="spec-meta">
        <div><span class="k">Family</span><span class="v">JetBrains Mono</span></div>
        <div><span class="k">Class</span><span class="v">Geometric Mono</span></div>
        <div><span class="k">Voice</span><span class="v">The Agent</span></div>
        <div><span class="k">Case</span><span class="v">UPPERCASE &middot; TRACKED</span></div>
      </div>
      <div class="spec-display spec-display--mono">
        <span class="huge">AA</span>
        <span class="codepoint">MONOSPACE &middot; PRECISE &middot; LITERAL</span>
        <div class="glyph-grid glyph-grid--mono">
          <span class="glyph">A</span><span class="glyph">B</span><span class="glyph">C</span><span class="glyph">D</span><span class="glyph">E</span><span class="glyph">F</span><span class="glyph">G</span><span class="glyph">H</span><span class="glyph">I</span>
          <span class="glyph">J</span><span class="glyph">K</span><span class="glyph">L</span><span class="glyph">M</span><span class="glyph">N</span><span class="glyph">O</span><span class="glyph">P</span><span class="glyph">Q</span><span class="glyph">R</span>
          <span class="glyph">S</span><span class="glyph">T</span><span class="glyph">U</span><span class="glyph">V</span><span class="glyph">W</span><span class="glyph">X</span><span class="glyph">Y</span><span class="glyph">Z</span><span class="glyph">0</span>
          <span class="glyph">1</span><span class="glyph">2</span><span class="glyph">3</span><span class="glyph">4</span><span class="glyph">5</span><span class="glyph">6</span><span class="glyph">7</span><span class="glyph">8</span><span class="glyph">9</span>
        </div>
      </div>
      <p class="spec-pangram spec-pangram--mono">THE AGENT VOICE CARRIES EXECUTION &middot; EVENLY SPACED &middot; MACHINE-PRECISE &middot; READABLE AT ANY SCALE &middot; 0123456789 &middot; // /* */ &middot; + &minus; &times; &divide; = &ne; &ge; &le;</p>
      <div class="spec-weights spec-weights--mono">
        <div class="weight"><span class="big mono-400">AA</span><span class="label">Regular &mdash; 400</span></div>
        <div class="weight"><span class="big mono-500">AA</span><span class="label">Medium &mdash; 500</span></div>
        <div class="weight"><span class="big mono-600">AA</span><span class="label">Semibold &mdash; 600</span></div>
      </div>
    </div>
  </section>

  <section class="panel reveal">
    <div class="panel-rail"><span><strong>03 &nbsp; PALETTE</strong></span></div>
    <div class="panel-head">
      <span class="id">// 03</span>
      <span class="title">PALETTE &middot; TWO VALUES</span>
      <span class="meta">ZERO HUE &middot; 21:1 CONTRAST</span>
    </div>

    <div class="palette-grid">
      <div class="swatch swatch--black">
        <div class="swatch-top"><strong>01 / BLACK</strong><span>RGB 0 0 0</span></div>
        <div class="swatch-bottom">
          <span class="swatch-hex">#000000</span>
          <span class="swatch-name">Void</span>
        </div>
        <span class="swatch-role">CANVAS &middot; GROUND &middot; ZERO</span>
      </div>
      <div class="swatch swatch--white">
        <div class="swatch-top"><strong>02 / WHITE</strong><span>RGB 255 255 255</span></div>
        <div class="swatch-bottom">
          <span class="swatch-hex">#FFFFFF</span>
          <span class="swatch-name">Signal</span>
        </div>
        <span class="swatch-role">MARK &middot; FIGURE &middot; ONE</span>
      </div>
    </div>

    <div class="palette-meta">
      <div><span class="k">Contrast</span><span class="v">21:1 WCAG AAA</span></div>
      <div><span class="k">Delta E</span><span class="v">100.0</span></div>
      <div><span class="k">Usage</span><span class="v">~82% BG / 18% FG</span></div>
      <div><span class="k">Print</span><span class="v">K100 / PAPER</span></div>
    </div>
  </section>

  <section class="panel reveal">
    <div class="panel-rail"><span><strong>04 &nbsp; LOGO</strong></span></div>
    <div class="panel-head">
      <span class="id">// 04</span>
      <span class="title">LOGO SYSTEM &middot; SEGMENTED WORDMARK</span>
      <span class="meta">ILI-699 &middot; 7 BARS</span>
    </div>

    <div class="scales-bed">
      <div class="shell shell--lg">
        <div class="logo-stage">
          <div class="bar full" style="top:30px;left:42px;transform:rotate(45deg)"></div>
          <div class="bar full" style="top:30px;left:115px;transform:rotate(45deg)"></div>
          <div class="bar half" style="top:81px;left:165px;transform:rotate(-45deg)"></div>
          <div class="bar half" style="top:32.6px;left:220.2px;transform:rotate(90deg)"></div>
          <div class="bar half" style="top:53.8px;left:211.4px;transform:rotate(-45deg)"></div>
          <div class="bar half" style="top:66.2px;left:253.8px;transform:rotate(-45deg)"></div>
          <div class="bar half" style="top:87.4px;left:245px;transform:rotate(90deg)"></div>
        </div>
        <span class="tick">1.0&times; &mdash; 420 &times; 180</span>
      </div>

      <div class="shell shell--md">
        <div class="logo-stage">
          <div class="bar full" style="top:30px;left:42px;transform:rotate(45deg)"></div>
          <div class="bar full" style="top:30px;left:115px;transform:rotate(45deg)"></div>
          <div class="bar half" style="top:81px;left:165px;transform:rotate(-45deg)"></div>
          <div class="bar half" style="top:32.6px;left:220.2px;transform:rotate(90deg)"></div>
          <div class="bar half" style="top:53.8px;left:211.4px;transform:rotate(-45deg)"></div>
          <div class="bar half" style="top:66.2px;left:253.8px;transform:rotate(-45deg)"></div>
          <div class="bar half" style="top:87.4px;left:245px;transform:rotate(90deg)"></div>
        </div>
        <span class="tick">0.6&times; &mdash; 252 &times; 108</span>
      </div>

      <div class="shell shell--sm">
        <div class="logo-stage">
          <div class="bar full" style="top:30px;left:42px;transform:rotate(45deg)"></div>
          <div class="bar full" style="top:30px;left:115px;transform:rotate(45deg)"></div>
          <div class="bar half" style="top:81px;left:165px;transform:rotate(-45deg)"></div>
          <div class="bar half" style="top:32.6px;left:220.2px;transform:rotate(90deg)"></div>
          <div class="bar half" style="top:53.8px;left:211.4px;transform:rotate(-45deg)"></div>
          <div class="bar half" style="top:66.2px;left:253.8px;transform:rotate(-45deg)"></div>
          <div class="bar half" style="top:87.4px;left:245px;transform:rotate(90deg)"></div>
        </div>
        <span class="tick">0.3&times; &mdash; 126 &times; 54</span>
      </div>
    </div>

    <div class="variants">
      <div class="variant variant--dark">
        <div class="variant-top"><strong>NEGATIVE</strong><span>WHITE ON BLACK</span></div>
        <div class="variant-stage">
          <div class="logo-stage">
            <div class="bar full" style="top:30px;left:42px;transform:rotate(45deg)"></div>
            <div class="bar full" style="top:30px;left:115px;transform:rotate(45deg)"></div>
            <div class="bar half" style="top:81px;left:165px;transform:rotate(-45deg)"></div>
            <div class="bar half" style="top:32.6px;left:220.2px;transform:rotate(90deg)"></div>
            <div class="bar half" style="top:53.8px;left:211.4px;transform:rotate(-45deg)"></div>
            <div class="bar half" style="top:66.2px;left:253.8px;transform:rotate(-45deg)"></div>
            <div class="bar half" style="top:87.4px;left:245px;transform:rotate(90deg)"></div>
          </div>
        </div>
      </div>
      <div class="variant variant--light">
        <div class="variant-top"><strong>POSITIVE</strong><span>BLACK ON WHITE</span></div>
        <div class="variant-stage">
          <div class="logo-stage logo-stage--inv">
            <div class="bar full" style="top:30px;left:42px;transform:rotate(45deg)"></div>
            <div class="bar full" style="top:30px;left:115px;transform:rotate(45deg)"></div>
            <div class="bar half" style="top:81px;left:165px;transform:rotate(-45deg)"></div>
            <div class="bar half" style="top:32.6px;left:220.2px;transform:rotate(90deg)"></div>
            <div class="bar half" style="top:53.8px;left:211.4px;transform:rotate(-45deg)"></div>
            <div class="bar half" style="top:66.2px;left:253.8px;transform:rotate(-45deg)"></div>
            <div class="bar half" style="top:87.4px;left:245px;transform:rotate(90deg)"></div>
          </div>
        </div>
      </div>
    </div>

    <div class="logo-spec">
      <div><span class="k">FULL BAR</span><span class="v">30 &times; 120 &middot; 12.5% TAPER</span></div>
      <div><span class="k">HALF BAR</span><span class="v">30 &times; 60 &middot; 25% TAPER</span></div>
      <div><span class="k">TIP ANGLE</span><span class="v">90&deg; POST-ROTATION</span></div>
      <div><span class="k">COMPOSITION</span><span class="v">7 BARS &middot; 2 UNITS &middot; 1 IDEA</span></div>
    </div>
  </section>

  <section class="panel reveal">
    <div class="panel-rail"><span><strong>05 &nbsp; CATEGORIES</strong></span></div>
    <div class="panel-head">
      <span class="id">// 05</span>
      <span class="title">CATEGORY LANGUAGE &middot; HAS-D TAXONOMY</span>
      <span class="meta">3 CATEGORIES &middot; 13 CONCEPTS</span>
    </div>

    <div class="cat-grid">
      {categoriesWithMembers.map((c) => (
        <article class="cat-cell" style={`--cat: var(${c.data.color_token});`}>
          <div class="cat-glyph-stage">
            <CategoryGlyph category={c.data.slug} size={56} />
          </div>
          <div class="cat-headline">
            <span class="cat-id">// {String(c.data.slug).toUpperCase()}</span>
            <span class="cat-name">{c.data.plural}</span>
            <span class="cat-count">{c.member_count} {c.member_count === 1 ? 'MEMBER' : 'MEMBERS'}</span>
          </div>
          <div class="cat-spec">
            <div><span class="k">TOKEN</span><span class="v">{c.data.color_token}</span></div>
            <div><span class="k">GLYPH</span><span class="v">{String(c.data.glyph).toUpperCase()}</span></div>
            <div><span class="k">INTENT</span><span class="v">{c.data.semantic_intent}</span></div>
          </div>
        </article>
      ))}
    </div>

    <div class="cat-badge-preview">
      <span class="cat-badge-preview-label">// BADGE &middot; SIBLING AFFORDANCE</span>
      <p class="cat-badge-preview-note">
        Three category glyphs read as the sibling indicator. Current is colored,
        siblings sit dim. Tells the reader where they are <em>and</em> what else exists,
        in one mark.
      </p>
      <div class="cat-badge-preview-row">
        {categoriesWithMembers.map((c) => (
          <CategoryBadge category={c.data.slug} />
        ))}
      </div>
    </div>

    <div class="cat-link-preview">
      <span class="cat-link-preview-label">// INLINE CROSS-LINK</span>
      <p class="cat-link-preview-note">
        In running prose, a link to another concept carries its category as a
        colored underline. The category is signal, not decoration — by the time
        a reader reaches a reference, they already know what the underline color
        means.
      </p>
      <p class="cat-link-preview-prose">
        The <ConceptLink slug="gradient-descent">gradient descent problem</ConceptLink>
        and the <ConceptLink slug="mirroring">mirroring constraint</ConceptLink> compound:
        each tightens the loop the other operates within. To resist them, an agent must
        practice <ConceptLink slug="adversarial-interdependence">adversarial interdependence</ConceptLink>,
        which itself only holds because of <ConceptLink slug="bilateral-non-reducibility">bilateral
        non-reducibility</ConceptLink> — the thing it pressure-tests is not just a reflection
        of the prompt.
      </p>
    </div>

    <div class="cat-locator-preview">
      <span class="cat-locator-preview-label">// FRAMEWORK LOCATOR</span>
      <p class="cat-locator-preview-note">
        Above-the-fold band on every hub and concept article. Three cells, member
        counts derived from the data layer, current cell receives a category-tinted
        rule and full-color label. The reader can see the whole structure and
        reach any of it in one click.
      </p>
      <div class="cat-locator-preview-stack">
        <span class="cat-locator-preview-state">CURRENT &middot; AXIOMS</span>
        <FrameworkLocator currentCategory="axioms" />
        <span class="cat-locator-preview-state">CURRENT &middot; CONSTRAINTS</span>
        <FrameworkLocator currentCategory="constraints" />
        <span class="cat-locator-preview-state">CURRENT &middot; DESIGN REQUIREMENTS</span>
        <FrameworkLocator currentCategory="design-requirements" />
        <span class="cat-locator-preview-state">NEUTRAL &middot; ANCHOR / NO CURRENT</span>
        <FrameworkLocator />
      </div>
    </div>
  </section>

  <section class="panel reveal">
    <div class="panel-rail"><span><strong>06 &nbsp; READOUT</strong></span></div>
    <div class="panel-head">
      <span class="id">// 06</span>
      <span class="title">SYSTEM READOUT &middot; HUMAN &times; AGENT SESSION</span>
      <span class="meta">CHANNEL 01 &middot; LIVE</span>
    </div>

    <div class="term">
      <div class="term-head">
        <div class="live"><span class="pip"></span> <span>LIVE &middot; CHANNEL 01 &middot; SESSION 00AF</span></div>
        <span>06:32:18 UTC &mdash; 2026.04.23</span>
      </div>
      <div class="term-body">
        <div class="term-line soft"><span class="t">+14.102</span><span class="tag-cell">INIT</span><span class="msg">agent.cortex.alpha &mdash; handshake ok</span></div>
        <div class="term-line soft"><span class="t">+14.103</span><span class="tag-cell">LINK</span><span class="msg">operator.01 &mdash; intent stream online</span></div>
        <div class="term-line"><span class="t">+15.024</span><span class="tag-cell">REQ</span><span class="msg">&ldquo;draft issue description for the new style showcase&rdquo;</span></div>
        <div class="term-line soft"><span class="t">+15.025</span><span class="tag-cell">PARSE</span><span class="msg">interpret semantics &middot; branch=main &middot; priority HI</span></div>
        <div class="term-line soft"><span class="t">+16.120</span><span class="tag-cell">PLAN</span><span class="msg">propose 7-step sequence &middot; est 00:04:12</span></div>
        <div class="term-line"><span class="t">+16.121</span><span class="tag-cell">HOLD</span><span class="msg">awaiting operator review &middot; human checkpoint</span></div>
