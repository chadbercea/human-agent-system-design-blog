---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getSortedArticles } from '../../lib/articles.ts';

export async function getStaticPaths() {
  if (import.meta.env.PROD) return [];
  return [{ params: { tool: 'type' } }, { params: { tool: 'prose' } }];
}

const { tool } = Astro.params;
const articles = await getSortedArticles();
const title = tool === 'prose' ? 'Dev — Prose specimen' : 'Dev — Type specimen';
---

<SiteLayout title={title} articles={articles}>
  {
    tool === 'type' ? (
      <div class="specimen">
        {/* ── Font stack overview ─────────────────────────── */}
        <div class="specimen__eyebrow">The Font Stack</div>
        <h1 class="specimen__title">Four Fonts, One System</h1>
        <p class="specimen__subtitle">Display + UI + Prose + Mono</p>

        <hr class="specimen__rule" />

        {/* ── Display: Lato Black ─────────────────────────── */}
        <div class="specimen__eyebrow">Display — Lato Black 900</div>
        <h1 class="specimen__title">Big Blocky Thicc Titles</h1>
        <p class="specimen__body">
          Lato Black at 2rem. Built for impact. The kind of heading you feel
          in your chest before you read the words.
        </p>

        <hr class="specimen__rule" />

        {/* ── UI: Montserrat ──────────────────────────────── */}
        <div class="specimen__eyebrow">UI — Montserrat Bold 700</div>
        <p class="specimen__subtitle">All Caps Subtitles In Montserrat ExtraBold</p>
        <p class="specimen__body">
          Montserrat handles eyebrows (the tiny labels above titles) and
          subtitles. Always uppercase, always tracked out, always bold.
        </p>

        <hr class="specimen__rule" />

        {/* ── Prose: Source Serif 4 ───────────────────────── */}
        <div class="specimen__eyebrow">Prose — Source Serif 4</div>
        <h1 class="specimen__title">Long-Form Reading</h1>
        <p class="specimen__body">
          Source Serif 4 is the workhorse. Neutral, screen-optimized, designed for
          long paragraphs at 18px on dark backgrounds. It doesn't try to be literary
          or editorial — it just gets out of the way and lets you read. The rhythm is
          steady, the x-height is generous, and the contrast is tuned for backlit screens.
        </p>
        <p class="specimen__body">
          Here's a second paragraph to feel the cadence. Good body type
          disappears. You stop noticing the font and start noticing the ideas.
          That's <em>exactly</em> what Source Serif does. It pairs with <strong>bold
          emphasis</strong> naturally and handles <a href="#">inline links</a> without
          breaking the texture of the paragraph.
        </p>

        <hr class="specimen__rule" />

        {/* ── Mono: JetBrains Mono ────────────────────────── */}
        <div class="specimen__eyebrow">Code — JetBrains Mono</div>
        <h1 class="specimen__title">Terminal Vibes</h1>
        <p class="specimen__body">
          Inline code like <code>const vibe = "immaculate"</code> gets the pill
          treatment. Ligatures are on: <code>=&gt;</code> <code>!==</code> <code>-&gt;</code> <code>&lt;=</code>.
        </p>
        <pre class="specimen__code"><code>{`// JetBrains Mono in a code block
function deploy(config) {
  const { target, env } = config;
  if (env !== "production") return;

  console.log(\`deploying to \${target}...\`);
  return fetch(target, {
    method: "POST",
    headers: { "x-deploy-key": process.env.KEY },
    body: JSON.stringify({ ts: Date.now() }),
  });
}`}</code></pre>

        <hr class="specimen__rule" />

        {/* ── Metadata specimen ───────────────────────────── */}
        <div class="specimen__eyebrow">Metadata — Mono + UI Together</div>
        <h1 class="specimen__title">How It All Plays Together</h1>
        <div class="specimen__meta-row">
          <span class="specimen__meta-date">2026-04-02</span>
          <span class="specimen__meta-tag">DESIGN SYSTEMS</span>
          <span class="specimen__meta-tag">TYPOGRAPHY</span>
          <span class="specimen__meta-reading">6 min read</span>
        </div>
        <p class="specimen__body">
          Dates and reading time in JetBrains Mono with tabular figures.
          Tags in Montserrat all-caps. The two "system" fonts share the same
          visual register without competing.
        </p>

        <hr class="specimen__rule" />

        {/* ── Full article simulation ─────────────────────── */}
        <div class="specimen__eyebrow">Full Article Preview</div>
        <h1 class="specimen__title">Why Agents Need Feedback Loops</h1>
        <p class="specimen__subtitle">Building Adaptive Systems That Learn</p>
        <div class="specimen__meta-row">
          <span class="specimen__meta-date">2026-03-28</span>
          <span class="specimen__meta-tag">AGENT DESIGN</span>
          <span class="specimen__meta-reading">8 min read</span>
        </div>
        <p class="specimen__body">
          An autonomous agent without a feedback loop is a missile — it commits
          fully to its initial trajectory and can't correct course. The most capable
          agents aren't the ones with the biggest context windows or the most tools.
          They're the ones that <em>notice when something isn't working</em> and
          adjust before the damage compounds.
        </p>
        <p class="specimen__body">
          This is the fundamental tension in agent design: you want the system to be
          autonomous enough to handle multi-step tasks without hand-holding, but
          self-aware enough to recognize when its plan has gone sideways. The sweet
          spot is <strong>structured reflection</strong> — checkpoints where the agent
          evaluates its own progress against the original intent.
        </p>
        <pre class="specimen__code"><code>{`interface FeedbackLoop {
  observe(): Observation;
  evaluate(obs: Observation): Score;
  adjust(score: Score): Action;
  threshold: number; // below this => escalate to human
}`}</code></pre>
        <p class="specimen__body">
          The <code>threshold</code> parameter is where the magic happens. Set it
          too low and the agent never asks for help. Too high and it's just a
          chatbot with extra steps. The right value depends on the domain, the
          stakes, and how much you trust the agent's self-evaluation.
        </p>
      </div>
    ) : (
      <article class="prose">
        <h1>Prose specimen</h1>

        <p>
          This page exercises every HTML element that the <code>.prose</code> class
          styles. It exists so you can assess the reading experience as a whole — does
          it feel settled and calm? Open this in a browser and read it top to bottom.
        </p>

        <p>
          A second paragraph follows the first to verify <code>p + p</code> spacing.
          The gap between consecutive paragraphs should be exactly
          <code>var(--space-6)</code> — enough to breathe, not enough to fragment the
          thought. Notice how <strong>bold text</strong> and <em>italic text</em> sit
          inside the flow without breaking the line rhythm.
        </p>

        <p>
          Here is a third paragraph with a <a href="#">sample link</a> embedded in the
          prose. The underline should be faint at rest and brighten on hover. Links
          should never change font-weight — that would reflow the text around them.
        </p>

        <h2>Heading level two</h2>

        <p>
          An h2 signals a major section break. It gets generous top margin
          (<code>--space-16</code>) to separate it from preceding content, and tight
          leading to keep multi-line headings compact.
        </p>

        <h3>Heading level three</h3>

        <p>
          An h3 marks a subsection. Its top margin (<code>--space-12</code>) is
          smaller than h2 but still creates a clear visual break. The font size steps
          down to <code>--text-xl</code>.
        </p>

        <h4>Heading level four</h4>

        <p>
          An h4 is for fine-grained structure within a subsection. It uses medium
          weight rather than bold to differentiate it from h3 while keeping the
          hierarchy legible.
        </p>

        <h2>Blockquotes</h2>

        <blockquote>
          <p>
            The best interface is no interface. The best system is one that recedes so
            completely that the human forgets it is there.
          </p>
        </blockquote>

        <p>
          The blockquote above uses a thin left border, italic style, and slightly
          dimmed colour. No background, no box — just the left rule.
        </p>

        <h2>Code</h2>

        <p>
          Inline code like <code>const x = 42</code> should blend into the paragraph
          without calling excessive attention to itself. It gets a subtle background
          and slightly smaller font size (<code>0.875em</code>).
        </p>

        <pre><code>{`function greet(name: string): string {
  // A simple greeting function to test code block rendering
  const greeting = \`Hello, \${name}!\`;
  console.log(greeting);
  return greeting;
}

// Call it
greet("world");`}</code></pre>

        <p>
          Code blocks get more padding (<code>--space-6</code>), a wider max-width
          (<code>--measure-wide</code>), and horizontal scroll when lines overflow. No
          border, no shadow.
        </p>

        <h2>Lists</h2>

        <p>An unordered list:</p>

        <ul>
          <li>Design tokens define the visual language</li>
          <li>Components consume tokens, never raw values</li>
          <li>
            Layouts compose components into pages
            <ul>
              <li>Nested items reduce spacing slightly</li>
              <li>This tests the nested list treatment</li>
            </ul>
          </li>
          <li>The system stays coherent at every level</li>
        </ul>

        <p>An ordered list:</p>

        <ol>
          <li>Read the design spec carefully</li>
          <li>Map spec tokens to existing CSS custom properties</li>
          <li>Implement the stylesheet element by element</li>
          <li>Build a specimen page to verify the result</li>
        </ol>

        <h2>Horizontal rule</h2>

        <p>
          A horizontal rule below separates thematic sections. It uses a single-pixel
          border in the border colour token with generous vertical margin.
        </p>

        <hr />

        <p>
          Content resumes after the rule. The spacing above and below should feel
          balanced — <code>--space-12</code> on each side.
        </p>

        <h2>Links and emphasis together</h2>

        <p>
          You can combine <strong><a href="#">bold links</a></strong> and
          <em><a href="#">italic links</a></em> and even
          <strong><em>bold italic text</em></strong> within the same paragraph. The
          prose should remain readable and the rhythm unbroken regardless of how many
          inline styles overlap.
        </p>

        <h3>Final subsection</h3>

        <p>
          This specimen is intentionally long enough to read as a real article. Scroll
          through it. Does the spacing feel consistent? Do the headings create a clear
          hierarchy? Does the overall texture feel settled and calm? If so, the prose
          stylesheet is doing its job.
        </p>
      </article>
    )
  }
</SiteLayout>

<style>
  .specimen {
    max-width: var(--measure);
  }

  /* ── Eyebrow ──────────────────────────────────────────── */
  .specimen__eyebrow {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-link);
    margin-bottom: var(--space-2);
  }

  /* ── Title: Lato Black ────────────────────────────────── */
  .specimen__title {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 2.5rem;
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0 0 var(--space-3);
    color: var(--color-text);
  }

  /* ── Subtitle: Montserrat ExtraBold all-caps ──────────── */
  .specimen__subtitle {
    font-family: var(--font-ui);
    font-weight: 800;
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4);
  }

  /* ── Body: Source Serif 4 ─────────────────────────────── */
  .specimen__body {
    font-family: var(--font-prose);
    font-size: var(--text-base);
    line-height: var(--leading-body);
    color: var(--color-text);
    margin: 0 0 var(--space-4);
  }

  .specimen__body em {
    font-style: italic;
  }

  .specimen__body strong {
    font-weight: 700;
  }

  .specimen__body a {
    color: var(--color-link);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  /* ── Inline code pills ────────────────────────────────── */
  .specimen__body code {
    font-family: var(--font-mono);
    font-size: 0.875em;
    font-variant-ligatures: contextual;
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    border-radius: 4px;
    padding: 0.1em 0.4em;
  }

  /* ── Code blocks ──────────────────────────────────────── */
  .specimen__code {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    line-height: 1.6;
    font-variant-ligatures: contextual;
    background: var(--color-surface);
    border: 1px solid var(--color-rule);
    border-left: 3px solid var(--color-link);
    border-radius: 2px;
    padding: var(--space-4);
    margin: var(--space-4) 0;
    overflow-x: auto;
  }

  .specimen__code code {
    font-family: inherit;
    font-size: inherit;
    background: none;
    border: none;
    padding: 0;
    border-radius: 0;
  }

  /* ── Metadata row ─────────────────────────────────────── */
  .specimen__meta-row {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
    flex-wrap: wrap;
  }

  .specimen__meta-date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-variant-numeric: tabular-nums;
    color: var(--color-text-muted);
  }

  .specimen__meta-tag {
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-link);
    background: color-mix(in srgb, var(--color-link) 12%, transparent);
    border-radius: 3px;
    padding: 0.15em 0.5em;
  }

  .specimen__meta-reading {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-variant-numeric: tabular-nums;
    color: var(--color-text-muted);
  }

  /* ── Rule ─────────────────────────────────────────────── */
  .specimen__rule {
    border: none;
    border-top: 1px solid var(--color-rule);
    margin: var(--space-8) 0;
  }
</style>
