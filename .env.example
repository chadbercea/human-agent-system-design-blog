# Public site URL (used for canonical links + sitemap).
PUBLIC_SITE_URL=

# Formspree form ID for the /contact form (the part after /f/ in the
# Formspree endpoint, e.g. https://formspree.io/f/xyzpqrst → xyzpqrst).
# When empty, the form renders but submission shows a config error.
PUBLIC_FORMSPREE_FORM_ID=
